@page "/Account/Register"

<PageTitle>Account creation unavailable</PageTitle>

<section class="account-page">
    <div class="page-hero page-hero--section account-page__hero">
        <p class="page-hero__eyebrow">Staff Access</p>
        <h1>Account creation is handled by an admin.</h1>
        <p class="page-hero__lead">
            Public self-registration is disabled. Ask a site <strong>Admin</strong> to create your staff account,
            share your temporary password, and assign the roles you need.
        </p>
    </div>

    <div class="account-grid">
        <section class="admin-card account-panel">
            <div class="admin-card__header">
                <h2>What to do next</h2>
                <span class="admin-card__badge">Onboarding</span>
            </div>

            <div class="account-panel__body">
                <ul class="feature-list">
                    <li>Contact a site <strong>Admin</strong> so they can create your account from User Management.</li>
                    <li>If confirmed-account enforcement is active, the same <strong>Admin</strong> can confirm the account there too.</li>
                    <li>Once the account exists, return to the login page and sign in with the temporary password you were given.</li>
                </ul>
            </div>
        </section>

        <section class="admin-card account-panel">
            <div class="admin-card__header">
                <h2>Already have an account?</h2>
                <span class="admin-card__badge">Next step</span>
            </div>

            <div class="account-panel__body">
                <p>Use the normal staff login flow if an admin has already created your account.</p>
                <div class="account-form__actions">
                    <a class="hero-actions__link hero-actions__link--primary account-form__submit" href="/Account/Login" data-enhance-nav="false">Go to login</a>
                </div>
            </div>
        </section>
    </div>
</section>
