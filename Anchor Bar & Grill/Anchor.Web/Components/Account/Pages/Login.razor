@page "/Account/Login"

@using System.ComponentModel.DataAnnotations
@using Anchor.Domain.Identity.Configuration
@using Microsoft.AspNetCore.Identity
@using Anchor.Infrastructure.Data

@inject IConfirmedAccountAccessService ConfirmedAccountAccessService
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject ILogger<Login> Logger
@inject IdentityRedirectManager RedirectManager

<PageTitle>Log in</PageTitle>

<section class="account-page">
    <div class="page-hero page-hero--section account-page__hero">
        <p class="page-hero__eyebrow">Account Access</p>
        <h1>Log in</h1>
        <p class="page-hero__lead">
            Sign in to manage site content and keep the guest-facing information for The Anchor Bar &amp; Grill up to date.
        </p>
    </div>

    <div class="account-grid">
        <section class="admin-card account-panel">
            <div class="admin-card__header">
                <h2>Use a local account to log in.</h2>
                <span class="admin-card__badge">Secure Access</span>
            </div>

            <StatusMessage Message="@errorMessage" />

            <EditForm EditContext="editContext" method="post" OnSubmit="LoginUser" FormName="login" class="editor-form account-form">
                <DataAnnotationsValidator />
                <ValidationSummary class="validation-message account-form__validation" role="alert" />

                <div class="editor-form__grid">
                    <label>
                        Email
                        <CommitAwareInputText @bind-Value="Input.Email" id="Input.Email" class="account-form__input" autocomplete="username webauthn" aria-required="true" placeholder="name@example.com" />
                        <ValidationMessage For="() => Input.Email" class="validation-message" />
                    </label>
                    <label>
                        Password
                        <CommitAwareInputText Type="password" @bind-Value="Input.Password" id="Input.Password" class="account-form__input" autocomplete="current-password" aria-required="true" placeholder="Password" />
                        <ValidationMessage For="() => Input.Password" class="validation-message" />
                    </label>
                    <label class="editor-form__toggle">
                        <span>Remember me</span>
                        <div class="editor-form__toggle-row">
                            <InputCheckbox @bind-Value="Input.RememberMe" class="account-form__check" />
                            <small>Keep the session active on this device for faster admin access later.</small>
                        </div>
                    </label>
                </div>

                <div class="account-form__actions">
                    <button type="submit" class="hero-actions__link hero-actions__link--primary account-form__submit">Log in</button>
                </div>

                <div class="account-form__divider">
                    <span>Or</span>
                </div>

                <div class="account-form__actions">
                    <PasskeySubmit Operation="PasskeyOperation.Request" Name="Input.Passkey" EmailName="Input.Email" class="hero-actions__link hero-actions__link--secondary account-form__passkey">Log in with a passkey</PasskeySubmit>
                </div>

                <div class="account-links">
                    <p>
                        <a href="/Account/ForgotPassword" data-enhance-nav="false">Forgot your password?</a>
                    </p>
                    <p>
                        New staff accounts must be created by an <strong>Admin</strong>.
                    </p>
                    <p>
                        <a href="/Account/ResendEmailConfirmation" data-enhance-nav="false">Resend email confirmation</a>
                    </p>
                </div>
            </EditForm>
        </section>

    </div>
</section>

@code {
    private string? errorMessage;
    private EditContext editContext = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override void OnInitialized()
    {
        Input ??= new();

        editContext = new EditContext(Input);
    }

    public async Task LoginUser()
    {
        if (!string.IsNullOrEmpty(Input.Passkey?.Error))
        {
            errorMessage = $"Error: {Input.Passkey.Error}";
            return;
        }

        SignInResult result;
        ApplicationUser? resolvedUser = null;

        if (!string.IsNullOrEmpty(Input.Passkey?.CredentialJson))
        {
            if (!string.IsNullOrWhiteSpace(Input.Email))
            {
                resolvedUser = await UserManager.FindByEmailAsync(Input.Email);
            }

            var accessDecision = await ConfirmedAccountAccessService.EvaluateAsync(resolvedUser?.AccountConfirmed == true);
            if (accessDecision.IsConfirmationRequired)
            {
                if (string.IsNullOrWhiteSpace(Input.Email))
                {
                    errorMessage = "Error: Enter your email address before using a passkey while confirmed-account access is enabled.";
                    return;
                }

                if (!accessDecision.IsAccessAllowed)
                {
                    errorMessage = "Error: Your account must be confirmed by an administrator before you can sign in.";
                    return;
                }
            }

            // When performing passkey sign-in, don't perform form validation.
            result = await SignInManager.PasskeySignInAsync(Input.Passkey.CredentialJson);
        }
        else
        {
            if (!editContext.Validate())
            {
                return;
            }

            resolvedUser = await UserManager.FindByEmailAsync(Input.Email);
            if (resolvedUser is null)
            {
                errorMessage = "Error: Invalid login attempt.";
                return;
            }

            result = await SignInManager.CheckPasswordSignInAsync(resolvedUser, Input.Password, lockoutOnFailure: false);

            if (result.Succeeded)
            {
                var accessDecision = await ConfirmedAccountAccessService.EvaluateAsync(resolvedUser.AccountConfirmed);
                if (!accessDecision.IsAccessAllowed)
                {
                    errorMessage = "Error: Your account must be confirmed by an administrator before you can sign in.";
                    return;
                }

                await SignInManager.SignInAsync(resolvedUser, isPersistent: Input.RememberMe);
            }
        }

        if (result.Succeeded)
        {
            Logger.LogInformation("User logged in.");

            if (resolvedUser?.MustChangePassword == true)
            {
                RedirectManager.RedirectTo("Account/Manage/ChangePassword", new() { ["forced"] = true });
                return;
            }

            RedirectManager.RedirectTo(ReturnUrl);
        }
        else if (result.RequiresTwoFactor)
        {
            RedirectManager.RedirectTo(
                "Account/LoginWith2fa",
                new() { ["returnUrl"] = ReturnUrl, ["rememberMe"] = Input.RememberMe });
        }
        else if (result.IsLockedOut)
        {
            Logger.LogWarning("User account locked out.");
            RedirectManager.RedirectTo("Account/Lockout");
        }
        else
        {
            errorMessage = "Error: Invalid login attempt.";
        }
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [Display(Name = "Remember me?")]
        public bool RememberMe { get; set; }

        public PasskeyInputModel? Passkey { get; set; }
    }
}

