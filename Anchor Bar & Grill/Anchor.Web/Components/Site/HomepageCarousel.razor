<section class="home-carousel"
         data-anchor-carousel="true"
         data-anchor-carousel-interval="@AutoAdvanceIntervalMs"
         aria-label="@Label"
         aria-roledescription="carousel"
         tabindex="0">
    <div class="home-carousel__viewport">
        @for (var index = 0; index < Slides.Count; index++)
        {
            var slide = Slides[index];
            var slideState = GetInitialSlideState(index);

            <figure class="home-carousel__slide @slideState"
                    data-anchor-carousel-slide
                    aria-hidden="@(index == 0 ? "false" : "true")"
                    aria-label="@(FormattableString.Invariant($"{index + 1} of {Slides.Count}"))"
                    aria-roledescription="slide">
                <img class="home-carousel__image" src="@slide.ImageSource" alt="@slide.AltText" />
            </figure>
        }

        @if (Slides.Count > 1)
        {
            <button type="button"
                    class="home-carousel__control home-carousel__control--prev"
                    data-anchor-carousel-prev
                    aria-label="Show the previous homepage photo">
                <span aria-hidden="true">&#8249;</span>
            </button>

            <div class="home-carousel__status">
                <div class="home-carousel__indicator-row" aria-label="Homepage photo slide selector">
                    @for (var index = 0; index < Slides.Count; index++)
                    {
                        var slide = Slides[index];

                        <button type="button"
                                class="home-carousel__indicator @(index == 0 ? "is-active" : null)"
                                data-anchor-carousel-to="@index"
                                aria-current="@(index == 0 ? "true" : "false")"
                                aria-label="Show slide @(index + 1): @slide.Title"></button>
                    }
                </div>

                <p class="home-carousel__count" data-anchor-carousel-count>1 / @Slides.Count</p>
            </div>

            <button type="button"
                    class="home-carousel__control home-carousel__control--next"
                    data-anchor-carousel-next
                    aria-label="Show the next homepage photo">
                <span aria-hidden="true">&#8250;</span>
            </button>
        }
    </div>

    <div id="@captionTrackId" class="home-carousel__caption-track" aria-live="polite" hidden>
        @for (var index = 0; index < Slides.Count; index++)
        {
            var slide = Slides[index];
            var isActive = index == 0;

            <div class="home-carousel__caption-panel @(isActive ? "is-active" : null)"
                 data-anchor-carousel-caption
                 aria-hidden="@(isActive ? "false" : "true")">
                <p class="home-carousel__eyebrow">@slide.Eyebrow</p>
                <p class="home-carousel__caption-title">@slide.Title</p>
                <p class="home-carousel__description">@slide.Description</p>
            </div>
        }
    </div>

    <button type="button"
            class="home-carousel__caption-toggle"
            data-anchor-carousel-caption-toggle
            aria-controls="@captionTrackId"
            aria-expanded="false">
        Show caption
    </button>
</section>

@code {
    [Parameter]
    [EditorRequired]
    public IReadOnlyList<HomepageCarouselSlide> Slides { get; set; } = Array.Empty<HomepageCarouselSlide>();

    [Parameter]
    public string Label { get; set; } = "Homepage photo highlights";

    [Parameter]
    public int AutoAdvanceIntervalMs { get; set; } = 5000;

    private readonly string captionTrackId = $"home-carousel-caption-{Guid.NewGuid():N}";

    private string GetInitialSlideState(int index)
    {
        if (index == 0)
        {
            return "is-active";
        }

        if (Slides.Count > 1 && index == Slides.Count - 1)
        {
            return "is-prev-1";
        }

        if (Slides.Count > 2 && index == Slides.Count - 2)
        {
            return "is-prev-2";
        }

        if (index == 1)
        {
            return "is-next-1";
        }

        if (index == 2)
        {
            return "is-next-2";
        }

        return "is-hidden";
    }
}
