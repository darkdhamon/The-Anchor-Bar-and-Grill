@using Microsoft.AspNetCore.Components.Routing

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <script>
        (() => {
            const themeKey = "anchor-theme";
            const root = document.documentElement;
            const cookieMatch = document.cookie.match(/(?:^|; )anchor-theme=([^;]+)/);
            const cookieTheme = cookieMatch ? decodeURIComponent(cookieMatch[1]) : null;

            let storedTheme = null;

            try {
                storedTheme = window.localStorage.getItem(themeKey);
            } catch {
                storedTheme = null;
            }

            const theme = storedTheme === "dark" || storedTheme === "light"
                ? storedTheme
                : cookieTheme === "dark" || cookieTheme === "light"
                    ? cookieTheme
                    : "light";

            root.classList.remove("anchor-theme-light", "anchor-theme-dark");
            root.classList.add(theme === "dark" ? "anchor-theme-dark" : "anchor-theme-light");
        })();
    </script>
    <ResourcePreloader />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700&family=Bebas+Neue&family=Patrick+Hand&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Anchor.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="PageRenderMode" />
</head>

<body>
    <Routes @rendermode="PageRenderMode" />
    <ReconnectModal />
    <script src="@Assets["theme.js"]"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="@Assets["Components/Account/Shared/PasskeySubmit.razor.js"]" type="module"></script>
</body>

</html>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private IComponentRenderMode? PageRenderMode =>
        HttpContext?.AcceptsInteractiveRouting() == true ? InteractiveServer : null;
}
