@page "/events"
@attribute [ExcludeFromInteractiveRouting]

<PageTitle>Events</PageTitle>

<section class="page-hero page-hero--section">
    <p class="page-hero__eyebrow">Events</p>
    <h1>Events mockup</h1>
    <p class="page-hero__lead">
        Events should feel like part of the Anchor identity, not a buried side page. The public schedule should show every upcoming event, including recurring nights that generate more than one date.
    </p>
</section>

<section class="section-shell">
    <div class="section-heading">
        <p class="section-heading__eyebrow">Upcoming Calendar</p>
        <h2>Show every currently scheduled event in one public-facing list.</h2>
    </div>

    <div class="event-card-grid">
        @foreach (var item in upcomingEvents)
        {
            <article class="event-card @(item.Image is not null ? "event-card--with-image" : "event-card--text-only")">
                @if (item.Image is not null)
                {
                    <div class="event-card__visual">
                        <img class="event-card__image" src="@item.Image.Source" alt="@item.Image.AltText" />
                    </div>
                }

                <div class="event-card__content">
                    <div class="event-card__top">
                        <div class="event-card__badges">
                            <span class="event-card__badge">@item.PromoBadge</span>
                            <span class="status-pill @(item.IsRecurring ? "status-pill--recurring" : "status-pill--one-time")">@item.ScheduleTypeLabel</span>
                        </div>
                        <p class="event-card__date">@item.DateLabel</p>
                    </div>

                    <h3>@item.Title</h3>
                    <p class="event-card__meta">@item.DateTimeLabel</p>
                    <p class="event-card__schedule">@item.ScheduleDetail</p>
                    <p>@item.Description</p>
                </div>
            </article>
        }
    </div>
</section>

<section class="section-shell">
    <div class="section-heading">
        <p class="section-heading__eyebrow">Planning Notes</p>
        <h2>Use this page to explain the weekly rhythm, every-other-week cadence, and monthly traditions.</h2>
    </div>

    <div class="rhythm-list">
        @foreach (var item in MockupContent.WeeklyRhythms)
        {
            <article class="rhythm-item">
                <h3>@item.Label</h3>
                <p>@item.Description</p>
            </article>
        }
    </div>
</section>

@code {
    private readonly DateOnly today = DateOnly.FromDateTime(DateTime.Today);
    private IReadOnlyList<UpcomingEventOccurrence> upcomingEvents => MockupContent.GetUpcomingEvents(today);
}
