@page "/events"
@attribute [ExcludeFromInteractiveRouting]

<PageTitle>Events</PageTitle>

<section class="page-hero page-hero--section">
    <p class="page-hero__eyebrow">Events</p>
    <h1>Upcoming events</h1>
    <p class="page-hero__lead">
        See the live public event calendar for the next @PublicEventsWindowDays days, including recurring nights expanded into their upcoming dates automatically.
    </p>
</section>

<section class="section-shell public-events-section">
    <div class="section-heading public-events-heading">
        <p class="section-heading__eyebrow">Upcoming Calendar</p>
        <h2>Plan around the real schedule at a glance.</h2>
        <p>Published one-time events and recurring favorites are listed in chronological order so guests can quickly pick the right night to visit.</p>
    </div>

    @if (upcomingEvents.Count > 0)
    {
        <div class="event-card-grid">
            @foreach (var item in upcomingEvents)
            {
                <article class="event-card @(item.ImagePath is not null ? "event-card--with-image" : "event-card--text-only")">
                    @if (item.ImagePath is not null)
                    {
                        <div class="event-card__visual">
                            <img class="event-card__image" src="@item.ImagePath" alt="@item.ImageAltText" />
                        </div>
                    }

                    <div class="event-card__content">
                        <div class="event-card__top">
                            <div class="event-card__badges">
                                <span class="event-card__badge">@item.PromoBadge</span>
                                <span class="status-pill @(item.IsRecurring ? "status-pill--recurring" : "status-pill--one-time")">@item.ScheduleTypeLabel</span>
                            </div>
                            <p class="event-card__date">@item.DateLabel</p>
                        </div>

                        <h3>@item.Title</h3>
                        <p class="event-card__meta">@item.DateTimeLabel</p>
                        <p class="event-card__schedule">@item.ScheduleSummary</p>

                        @if (!string.IsNullOrWhiteSpace(item.Summary))
                        {
                            <p class="event-card__summary">@item.Summary</p>
                        }

                        @if (!string.IsNullOrWhiteSpace(item.Description))
                        {
                            <p>@item.Description</p>
                        }
                    </div>
                </article>
            }
        </div>
    }
    else
    {
        <div class="public-events-support-grid">
            <article class="feature-card feature-card--tight menu-empty-state public-events-empty">
                <p class="feature-card__eyebrow">Nothing Scheduled Yet</p>
                <h3>No published events are on the calendar right now.</h3>
                <p>Check back soon for live music, community nights, and one-time specials as they are posted.</p>
            </article>

            <article class="feature-card feature-card--tight public-events-callout">
                <p class="feature-card__eyebrow">Plan Your Visit</p>
                <h3>Need the menu or contact details before you head over?</h3>
                <p>Use the live event calendar alongside the current menu and contact page so your whole group knows what to expect before arrival.</p>
                <div class="hero-actions">
                    <a class="hero-actions__link hero-actions__link--primary" href="/menu" data-enhance-nav="false">Browse the Menu</a>
                    <a class="hero-actions__link hero-actions__link--secondary" href="/contact" data-enhance-nav="false">Get Contact Info</a>
                </div>
            </article>
        </div>
    }
</section>

@if (upcomingEvents.Count > 0)
{
    <section class="public-events-callout-shell">
        <article class="feature-card feature-card--tight public-events-callout">
            <p class="feature-card__eyebrow">Plan Your Visit</p>
            <h3>Need the menu or contact details before you head over?</h3>
            <p>Use the live event calendar alongside the current menu and contact page so your whole group knows what to expect before arrival.</p>
            <div class="hero-actions">
                <a class="hero-actions__link hero-actions__link--primary" href="/menu" data-enhance-nav="false">Browse the Menu</a>
                <a class="hero-actions__link hero-actions__link--secondary" href="/contact" data-enhance-nav="false">Get Contact Info</a>
            </div>
        </article>
    </section>
}
