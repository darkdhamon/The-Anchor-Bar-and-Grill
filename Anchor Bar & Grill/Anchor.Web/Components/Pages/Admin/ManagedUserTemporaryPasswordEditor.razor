@using System.ComponentModel.DataAnnotations
@using Anchor.Domain.Identity.Users

<EditForm Model="input" OnValidSubmit="SaveAsync" FormName="@($"ResetTemporaryPassword.{User.UserId}")" class="editor-form account-form">
    <DataAnnotationsValidator />

    <div class="admin-card__header">
        <h4>Reset temporary password</h4>
        <span class="admin-card__badge">Admin only</span>
    </div>

    <div class="editor-form__grid">
        <label>
            New temporary password
            <CommitAwareInputText Type="password" @bind-Value="input.TemporaryPassword" id="@($"ResetPassword.TemporaryPassword.{User.UserId}")" autocomplete="new-password" placeholder="Set a new temporary password" />
            <ValidationMessage For="@(() => input.TemporaryPassword)" class="validation-message" />
        </label>
    </div>

    <p class="admin-field-note">
        Use this when a staff member forgets the current password. The next successful sign-in will still require the user to choose a new personal password.
    </p>

    <div class="action-row">
        <button type="submit" class="action-button action-button--secondary" disabled="@IsBusy">Save new temporary password</button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public ManagedUserSummary User { get; set; } = default!;

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<ResetManagedUserPasswordRequest> OnSave { get; set; }

    private TemporaryPasswordInputModel input = new();
    private string? loadedUserId;
    private bool wasBusy;

    protected override void OnParametersSet()
    {
        if (!string.Equals(loadedUserId, User.UserId, StringComparison.Ordinal))
        {
            loadedUserId = User.UserId;
            input = new TemporaryPasswordInputModel();
        }
        else if (wasBusy && !IsBusy)
        {
            input = new TemporaryPasswordInputModel();
        }

        wasBusy = IsBusy;
    }

    private async Task SaveAsync()
    {
        if (IsBusy)
        {
            return;
        }

        await OnSave.InvokeAsync(
            new ResetManagedUserPasswordRequest(
                User.UserId,
                input.TemporaryPassword));
    }

    private sealed class TemporaryPasswordInputModel
    {
        [Required(ErrorMessage = "Enter a temporary password before saving.")]
        [StringLength(100, ErrorMessage = "The temporary password must be at least {2} and at most {1} characters long.", MinimumLength = 6)]
        public string TemporaryPassword { get; set; } = "";
    }
}
