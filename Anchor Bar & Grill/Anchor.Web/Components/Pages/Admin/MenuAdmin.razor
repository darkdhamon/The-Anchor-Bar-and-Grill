@page "/admin/menu"
@using Anchor.Domain.Identity
@using Anchor.Domain.Menu
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Policy = ApplicationPolicies.MenuManagement)]

<PageTitle>Menu Editor</PageTitle>

<section class="admin-page menu-admin-page">
    <div class="page-hero page-hero--section">
        <p class="page-hero__eyebrow">Menu Management</p>
        <h1>Menu editor</h1>
        <p class="page-hero__lead">
            Manage the fixed Breakfast, Lunch, Dinner, and Drinks tabs from one place. This editor keeps
            sections, items, recurring specials, and per-tab hours together so staff can understand exactly
            what guests will see before they publish a change.
        </p>
    </div>

    <StatusMessage Message="@statusMessage" />

    @if (isLoading || menuView is null)
    {
        <section class="admin-card">
            <div class="admin-card__header">
                <h2>Loading menu data</h2>
                <span class="admin-card__badge">Please wait</span>
            </div>
            <p class="admin-field-note">Pulling the latest sections, items, specials, and service hours from the menu catalog.</p>
        </section>
    }
    else
    {
        <div class="admin-grid">
            <aside class="admin-help">
                <h2>How this page works</h2>
                <ul>
                    <li>Public tabs are fixed as Breakfast, Lunch, Dinner, and Drinks. Staff do not create or rename tabs here.</li>
                    <li>Sections are reusable containers. Food sections can serve Breakfast, Lunch, and Dinner items. Drink sections feed the Drinks tab only.</li>
                    <li>Use archive as the safe removal path when something should disappear from the guest menu without being permanently erased.</li>
                    <li>Permanent delete requires confirmation and should only be used after related items or specials have been moved or removed.</li>
                    <li>Recurring specials stay attached to a section so guests see them in context instead of in a disconnected weekly block.</li>
                    <li>Menu hours are edited per fixed tab and per day. Staff can type shorthand like 1300 or 1pm, or pick from the reusable time list, including after-midnight closing times for drinks when needed.</li>
                </ul>
            </aside>

            <div class="admin-stack">
                <section class="admin-card">
                    <div class="admin-card__header">
                        <h2>Section editor</h2>
                        <span class="admin-card__badge">Step 1</span>
                    </div>

                    <div class="editor-form__grid">
                        <label>
                            Section name
                            <input type="text" @bind="sectionForm.Name" />
                            <small>Use clear guest-facing names like Appetizers, Burgers, or Cocktails.</small>
                        </label>
                        <label>
                            Menu family
                            <select @bind="sectionForm.Family">
                                <option value="@MenuFamily.Food">Food</option>
                                <option value="@MenuFamily.Drink">Drink</option>
                            </select>
                            <small>Food sections support Breakfast, Lunch, and Dinner items. Drink sections feed Drinks only.</small>
                        </label>
                        <label>
                            Sort order
                            <input type="number" @bind="sectionForm.SortOrder" />
                        </label>
                        <label class="editor-form__toggle">
                            <span>Guest visibility</span>
                            <div class="editor-form__toggle-row">
                                <input type="checkbox" @bind="sectionForm.IsVisibleToGuests" />
                                <small>Turn this off to hide the section from guests while keeping it in the editor.</small>
                            </div>
                        </label>
                        <label class="editor-form__toggle">
                            <span>Archive section</span>
                            <div class="editor-form__toggle-row">
                                <input type="checkbox" @bind="sectionForm.IsArchived" />
                                <small>Archived sections stay in the admin view but are never shown to guests.</small>
                            </div>
                        </label>
                    </div>

                    <div class="action-row action-row--wrap">
                        <button type="button" class="action-button action-button--primary" @onclick="SaveSectionAsync">
                            @(sectionForm.SectionId is null ? "Create section" : "Save section")
                        </button>
                        <button type="button" class="action-button action-button--secondary" @onclick="ResetSectionForm">Clear section form</button>
                    </div>

                    <p class="admin-field-note">If a section already contains items or recurring specials, keep its family consistent so food and drink content do not get mixed together.</p>
                </section>

                <section class="admin-card">
                    <div class="admin-card__header">
                        <h2>Item editor</h2>
                        <span class="admin-card__badge">Step 2</span>
                    </div>

                    <div class="editor-form__grid">
                        <label>
                            Section
                            <select value="@itemForm.SectionId" @onchange="HandleItemSectionChangedAsync">
                                <option value="">Select a section</option>
                                @foreach (var section in Sections.OrderBy(section => section.Family).ThenBy(section => section.SortOrder).ThenBy(section => section.Name, StringComparer.OrdinalIgnoreCase))
                                {
                                    <option value="@section.SectionId">@section.Name (@GetFamilyLabel(section.Family))</option>
                                }
                            </select>
                            <small>Choose the section first so the editor can apply the right tab rules.</small>
                        </label>
                        <label>
                            Menu item
                            <input type="text" @bind="itemForm.Name" />
                        </label>
                        <label>
                            Sort order
                            <input type="number" @bind="itemForm.SortOrder" />
                        </label>
                        <label>
                            Menu image path or URL (optional)
                            <input type="text" @bind="itemForm.ImagePath" />
                            <small>Leave blank when the item does not have a photo yet.</small>
                        </label>
                        <label>
                            Offer start date
                            <input type="date" value="@itemForm.OfferStartsOnText" @onchange="args => itemForm.OfferStartsOnText = args.Value?.ToString()" />
                        </label>
                        <label>
                            Offer end date (optional)
                            <input type="date" value="@itemForm.OfferEndsOnText" @onchange="args => itemForm.OfferEndsOnText = args.Value?.ToString()" />
                        </label>
                        <label class="editor-form__toggle">
                            <span>Guest visibility</span>
                            <div class="editor-form__toggle-row">
                                <input type="checkbox" @bind="itemForm.IsVisibleToGuests" />
                                <small>Hidden items stay available for editing and future reuse.</small>
                            </div>
                        </label>
                        <label class="editor-form__toggle">
                            <span>Archive item</span>
                            <div class="editor-form__toggle-row">
                                <input type="checkbox" @bind="itemForm.IsArchived" />
                                <small>Archived items are removed from the public menu and stay stored for later reference.</small>
                            </div>
                        </label>
                        <label class="editor-form__toggle">
                            <span>Seasonal item?</span>
                            <div class="editor-form__toggle-row">
                                <input type="checkbox" @bind="itemForm.IsSeasonal" />
                                <small>Seasonal and Limited Time labels are derived at runtime from the offer dates, not stored separately.</small>
                            </div>
                        </label>
                        <label class="editor-form__message">
                            Description
                            <textarea rows="4" @bind="itemForm.Description"></textarea>
                        </label>
                    </div>

                    <div class="menu-admin-subcard">
                        <div class="admin-card__header">
                            <h3>Guest tabs</h3>
                            <span class="admin-card__badge">Fixed tabs</span>
                        </div>

                        @if (SelectedItemSectionIsDrink)
                        {
                            <p class="admin-field-note">Drink items belong to the Drinks tab automatically because they live in a drink section.</p>
                        }
                        else if (SelectedItemSectionIsFood)
                        {
                            <div class="menu-admin-checkbox-grid">
                                <label class="editor-form__toggle-row">
                                    <input type="checkbox" @bind="itemForm.ShowBreakfast" />
                                    <span>Breakfast</span>
                                </label>
                                <label class="editor-form__toggle-row">
                                    <input type="checkbox" @bind="itemForm.ShowLunch" />
                                    <span>Lunch</span>
                                </label>
                                <label class="editor-form__toggle-row">
                                    <input type="checkbox" @bind="itemForm.ShowDinner" />
                                    <span>Dinner</span>
                                </label>
                            </div>
                        }
                        else
                        {
                            <p class="admin-field-note">Choose a section to assign the correct tab options for this item.</p>
                        }
                    </div>

                    <div class="menu-admin-subcard">
                        <div class="admin-card__header">
                            <h3>Price variants</h3>
                            <span class="admin-card__badge">@itemForm.PriceVariants.Count variant@(itemForm.PriceVariants.Count == 1 ? string.Empty : "s")</span>
                        </div>

                        <div class="menu-admin-price-stack">
                            @foreach (var variant in itemForm.PriceVariants)
                            {
                                <div class="menu-admin-price-row" @key="variant">
                                    <label>
                                        Label
                                        <input type="text" @bind="variant.Label" />
                                    </label>
                                    <label>
                                        Amount
                                        <input type="number" step="0.01" @bind="variant.AmountText" />
                                    </label>
                                    <label>
                                        Sort order
                                        <input type="number" @bind="variant.SortOrder" />
                                    </label>
                                    <button type="button"
                                            class="action-button action-button--danger"
                                            disabled="@(itemForm.PriceVariants.Count == 1)"
                                            @onclick="() => RemovePriceVariant(variant)">
                                        Remove
                                    </button>
                                </div>
                            }
                        </div>

                        <div class="action-row">
                            <button type="button" class="action-button action-button--secondary" @onclick="AddPriceVariant">Add another price</button>
                        </div>
                    </div>

                    <div class="action-row action-row--wrap">
                        <button type="button" class="action-button action-button--primary" @onclick="SaveItemAsync">
                            @(itemForm.ItemId is null ? "Create menu item" : "Save menu item")
                        </button>
                        <button type="button" class="action-button action-button--secondary" @onclick="ResetItemForm">Clear item form</button>
                    </div>

                    <p class="admin-field-note">A single-price item still needs one price variant. Use labels like Regular, Cup, Bowl, Single, or Double when guests need a clearer price breakdown.</p>
                </section>

                <section class="admin-card">
                    <div class="admin-card__header">
                        <h2>Recurring specials editor</h2>
                        <span class="admin-card__badge">Step 3</span>
                    </div>

                    <div class="editor-form__grid">
                        <label>
                            Menu tab
                            <select value="@specialForm.Tab" @onchange="HandleSpecialTabChangedAsync">
                                @foreach (var tab in Enum.GetValues<MenuTab>())
                                {
                                    <option value="@tab">@GetTabLabel(tab)</option>
                                }
                            </select>
                        </label>
                        <label>
                            Section
                            <select value="@specialForm.SectionId" @onchange="HandleSpecialSectionChangedAsync">
                                <option value="">Select a section</option>
                                @foreach (var section in SpecialSectionOptions)
                                {
                                    <option value="@section.SectionId">@section.Name</option>
                                }
                            </select>
                            <small>Recurring specials must stay inside a section that matches the selected tab family.</small>
                        </label>
                        <label>
                            Day of week
                            <select @bind="specialForm.DayOfWeek">
                                @foreach (var day in Enum.GetValues<DayOfWeek>())
                                {
                                    <option value="@day">@GetDayLabel(day)</option>
                                }
                            </select>
                        </label>
                        <label>
                            Sort order
                            <input type="number" @bind="specialForm.SortOrder" />
                        </label>
                        <label>
                            Special title
                            <input type="text" @bind="specialForm.Title" />
                        </label>
                        <label>
                            Time note
                            <input type="text" @bind="specialForm.TimeNote" />
                            <small>Examples: After 5:00 PM, All day, or 11:00 AM - 2:00 PM.</small>
                        </label>
                        <label>
                            Price or callout
                            <input type="text" @bind="specialForm.PriceNote" />
                        </label>
                        <label>
                            Featured menu item (optional)
                            <select @bind="specialForm.LinkedMenuItemId">
                                <option value="">No linked item</option>
                                @foreach (var item in SpecialLinkedItemOptions)
                                {
                                    <option value="@item.ItemId">@item.Name</option>
                                }
                            </select>
                        </label>
                        <label class="editor-form__toggle">
                            <span>Guest visibility</span>
                            <div class="editor-form__toggle-row">
                                <input type="checkbox" @bind="specialForm.IsVisibleToGuests" />
                                <small>Hidden specials stay stored but do not show to guests.</small>
                            </div>
                        </label>
                        <label class="editor-form__toggle">
                            <span>Archive special</span>
                            <div class="editor-form__toggle-row">
                                <input type="checkbox" @bind="specialForm.IsArchived" />
                                <small>Archived specials remain available for reference and future reuse.</small>
                            </div>
                        </label>
                        <label class="editor-form__message">
                            Guest-facing description
                            <textarea rows="4" @bind="specialForm.Description"></textarea>
                        </label>
                    </div>

                    <div class="action-row action-row--wrap">
                        <button type="button" class="action-button action-button--primary" @onclick="SaveRecurringSpecialAsync">
                            @(specialForm.SpecialId is null ? "Create recurring special" : "Save recurring special")
                        </button>
                        <button type="button" class="action-button action-button--secondary" @onclick="ResetSpecialForm">Clear special form</button>
                    </div>

                    <p class="admin-field-note">Recurring specials always show their weekday badge on the public menu. The extra Today badge appears automatically when guests are viewing that day.</p>
                </section>

                <section class="admin-card">
                    <div class="admin-card__header">
                        <h2>Menu hours editor</h2>
                        <span class="admin-card__badge">Step 4</span>
                    </div>

                    <div class="menu-hours-tab-row">
                        @foreach (var tab in HourTabs.OrderBy(tab => tab.Tab))
                        {
                            <button type="button"
                                    class="action-button @(serviceWindowForm.Tab == tab.Tab ? "action-button--primary" : "action-button--secondary")"
                                    @onclick="() => SelectHoursTabAsync(tab.Tab)">
                                @tab.Label
                            </button>
                        }
                    </div>

                    <div class="menu-hours-editor" @key="serviceWindowForm.Tab">
                        @foreach (var day in serviceWindowForm.Days)
                        {
                            <div class="menu-hours-editor__row" @key="(serviceWindowForm.Tab, day.DayOfWeek)">
                                <div class="menu-hours-editor__day">
                                    <strong>@GetDayLabel(day.DayOfWeek)</strong>
                                </div>
                                <label class="menu-hours-editor__toggle">
                                    <span>Available</span>
                                    <input type="checkbox" @bind="day.IsAvailable" />
                                </label>
                                <div>
                                    <label for="@GetHoursInputId(day.DayOfWeek, "open")">Open</label>
                                    <InputTimeComboBox Id="@GetHoursInputId(day.DayOfWeek, "open")"
                                                       @bind-Value="day.OpensAtText"
                                                       Placeholder="Type 1300 or pick a time"
                                                       ToggleAriaLabel="@($"Show {GetDayLabel(day.DayOfWeek)} opening times")"
                                                       Disabled="@(!day.IsAvailable)" />
                                </div>
                                <div>
                                    <label for="@GetHoursInputId(day.DayOfWeek, "close")">Close</label>
                                    <InputTimeComboBox Id="@GetHoursInputId(day.DayOfWeek, "close")"
                                                       @bind-Value="day.ClosesAtText"
                                                       Placeholder="Type 1300 or pick a time"
                                                       ToggleAriaLabel="@($"Show {GetDayLabel(day.DayOfWeek)} closing times")"
                                                       Disabled="@(!day.IsAvailable)" />
                                </div>
                                <label class="menu-hours-editor__toggle">
                                    <span>Closes next day</span>
                                    <input type="checkbox" @bind="day.ClosesNextDay" disabled="@(!day.IsAvailable)" />
                                </label>
                            </div>
                        }
                    </div>

                    <div class="action-row">
                        <button type="button" class="action-button action-button--primary" @onclick="SaveServiceHoursAsync">
                            Save @GetTabLabel(serviceWindowForm.Tab) hours
                        </button>
                    </div>

                    <p class="admin-field-note">Type shorthand like <code>1300</code>, <code>930</code>, or <code>1pm</code>, or open the list for a nearby half-hour pick. The field normalizes after you leave it. Use Closes next day when the tab stays open past midnight, such as Friday or Saturday drinks service.</p>
                </section>

                <section class="admin-card">
                    <div class="admin-card__header">
                        <h2>Current sections</h2>
                        <span class="admin-card__badge">@Sections.Count section@(Sections.Count == 1 ? string.Empty : "s")</span>
                    </div>

                    <div class="admin-list">
                        @foreach (var section in Sections.OrderBy(section => section.Family).ThenBy(section => section.SortOrder).ThenBy(section => section.Name, StringComparer.OrdinalIgnoreCase))
                        {
                            <article class="admin-list__item">
                                <div class="menu-admin-list-copy">
                                    <h3>@section.Name</h3>
                                    <div class="chip-list">
                                        <span class="chip chip--info">@GetFamilyLabel(section.Family)</span>
                                        <span class="chip chip--neutral">Order @section.SortOrder</span>
                                    </div>
                                    @if (section.StatusLabels.Count > 0)
                                    {
                                        <div class="menu-item__badges menu-item__badges--admin">
                                            @foreach (var label in section.StatusLabels)
                                            {
                                                <span class="status-pill @(GetStatusClass(label))">@label</span>
                                            }
                                        </div>
                                    }
                                </div>

                                <div class="admin-list__actions">
                                    <button type="button" class="action-button action-button--secondary" @onclick="() => EditSectionAsync(section)">Edit</button>
                                    <button type="button" class="action-button action-button--success" @onclick="() => ArchiveSectionAsync(section.SectionId)">Archive</button>
                                    <button type="button" class="action-button action-button--danger" @onclick="() => ToggleSectionDeleteAsync(section.SectionId)">
                                        @(pendingSectionDeleteId == section.SectionId ? "Confirm delete" : "Delete")
                                    </button>
                                </div>
                            </article>
                        }
                    </div>
                </section>

                <section class="admin-card">
                    <div class="admin-card__header">
                        <h2>Current menu items</h2>
                        <span class="admin-card__badge">@Items.Count item@(Items.Count == 1 ? string.Empty : "s")</span>
                    </div>

                    <div class="admin-list">
                        @foreach (var item in Items.OrderBy(item => item.Family).ThenBy(item => item.SectionName, StringComparer.OrdinalIgnoreCase).ThenBy(item => item.SortOrder).ThenBy(item => item.Name, StringComparer.OrdinalIgnoreCase))
                        {
                            <article class="admin-list__item">
                                <div class="menu-admin-list-copy">
                                    <h3>@item.Name</h3>
                                    <div class="chip-list">
                                        <span class="chip chip--info">@item.SectionName</span>
                                        <span class="chip chip--neutral">@GetItemTabSummary(item)</span>
                                        <span class="chip chip--neutral">Order @item.SortOrder</span>
                                    </div>

                                    @if (item.StatusLabels.Count > 0)
                                    {
                                        <div class="menu-item__badges menu-item__badges--admin">
                                            @foreach (var label in item.StatusLabels)
                                            {
                                                <span class="status-pill @(GetStatusClass(label))">@label</span>
                                            }
                                        </div>
                                    }

                                    <p>@item.Description</p>

                                    @if (item.OfferDateSummary is { } offerSummary)
                                    {
                                        <p class="menu-item__offer-range">@offerSummary</p>
                                    }
                                </div>

                                <div class="menu-admin-list-actions">
                                    <span class="admin-price">@GetPriceSummary(item)</span>
                                    <div class="admin-list__actions">
                                        <button type="button" class="action-button action-button--secondary" @onclick="() => EditItemAsync(item)">Edit</button>
                                        <button type="button" class="action-button action-button--success" @onclick="() => ArchiveItemAsync(item.ItemId)">Archive</button>
                                        <button type="button" class="action-button action-button--danger" @onclick="() => ToggleItemDeleteAsync(item.ItemId)">
                                            @(pendingItemDeleteId == item.ItemId ? "Confirm delete" : "Delete")
                                        </button>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                </section>

                <section class="admin-card">
                    <div class="admin-card__header">
                        <h2>Current recurring specials</h2>
                        <span class="admin-card__badge">@Specials.Count special@(Specials.Count == 1 ? string.Empty : "s")</span>
                    </div>

                    <div class="admin-list">
                        @foreach (var special in Specials.OrderBy(special => special.Tab).ThenBy(special => special.DayOfWeek).ThenBy(special => special.SortOrder).ThenBy(special => special.Title, StringComparer.OrdinalIgnoreCase))
                        {
                            <article class="admin-list__item">
                                <div class="menu-admin-list-copy">
                                    <h3>@special.Title</h3>
                                    <div class="chip-list">
                                        <span class="chip chip--info">@GetTabLabel(special.Tab)</span>
                                        <span class="chip chip--neutral">@special.SectionName</span>
                                        <span class="chip chip--neutral">@special.DayLabel</span>
                                    </div>

                                    @if (special.StatusLabels.Count > 0)
                                    {
                                        <div class="menu-item__badges menu-item__badges--admin">
                                            @foreach (var label in special.StatusLabels)
                                            {
                                                <span class="status-pill @(GetStatusClass(label))">@label</span>
                                            }
                                        </div>
                                    }

                                    <p>@special.Description</p>
                                    <p class="menu-item__offer-range">@special.TimeNote @(!string.IsNullOrWhiteSpace(special.LinkedMenuItemName) ? $"· Featured item: {special.LinkedMenuItemName}" : string.Empty)</p>
                                </div>

                                <div class="menu-admin-list-actions">
                                    <span class="admin-price">@special.PriceNote</span>
                                    <div class="admin-list__actions">
                                        <button type="button" class="action-button action-button--secondary" @onclick="() => EditSpecialAsync(special)">Edit</button>
                                        <button type="button" class="action-button action-button--success" @onclick="() => ArchiveSpecialAsync(special.SpecialId)">Archive</button>
                                        <button type="button" class="action-button action-button--danger" @onclick="() => ToggleSpecialDeleteAsync(special.SpecialId)">
                                            @(pendingSpecialDeleteId == special.SpecialId ? "Confirm delete" : "Delete")
                                        </button>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                </section>
            </div>
        </div>
    }
</section>
