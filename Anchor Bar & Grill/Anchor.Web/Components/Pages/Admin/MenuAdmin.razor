@page "/admin/menu"
@using Anchor.Domain.Identity
@using Anchor.Domain.Menu
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Policy = ApplicationPolicies.MenuManagement)]

<PageTitle>Menu Editor</PageTitle>

<section class="admin-page menu-admin-page">
    <div class="page-hero page-hero--section">
        <p class="page-hero__eyebrow">Menu Management</p>
        <h1>Menu editor</h1>
        <p class="page-hero__lead">
            Manage fixed public tabs from a browser-style editor. Hours stay in their own workspace, while
            Food and Drinks each use a section tree plus detail panel so staff can review live content before
            saving changes.
        </p>
    </div>

    <StatusMessage Message="@statusMessage" />

    @if (isLoading || menuView is null)
    {
        <section class="admin-card">
            <div class="admin-card__header">
                <h2>Loading menu data</h2>
                <span class="admin-card__badge">Please wait</span>
            </div>
            <p class="admin-field-note">Pulling the latest sections, special items, standard items, and service hours from the catalog.</p>
        </section>
    }
    else
    {
        <div class="menu-editor-shell">
            <aside class="admin-card menu-editor-nav" aria-label="Menu editor workspace navigation">
                <div class="admin-card__header">
                    <h2>Workspaces</h2>
                    <span class="admin-card__badge">Left rail</span>
                </div>

                <p class="admin-field-note">Switch between Food, Drinks, and Hours here. The rest of the page updates around the selected workspace.</p>

                <div class="menu-editor-tabs" role="tablist" aria-label="Menu editor workspaces" aria-orientation="vertical">
                    <button type="button"
                            role="tab"
                            class="@GetEditorTabClass(MenuEditorTab.Food)"
                            aria-selected="@(selectedEditorTab == MenuEditorTab.Food)"
                            @onclick="() => SelectEditorTab(MenuEditorTab.Food)">
                        Food
                    </button>
                    <button type="button"
                            role="tab"
                            class="@GetEditorTabClass(MenuEditorTab.Drinks)"
                            aria-selected="@(selectedEditorTab == MenuEditorTab.Drinks)"
                            @onclick="() => SelectEditorTab(MenuEditorTab.Drinks)">
                        Drinks
                    </button>
                    <button type="button"
                            role="tab"
                            class="@GetEditorTabClass(MenuEditorTab.Hours)"
                            aria-selected="@(selectedEditorTab == MenuEditorTab.Hours)"
                            @onclick="() => SelectEditorTab(MenuEditorTab.Hours)">
                        Hours
                    </button>
                </div>
            </aside>

            @if (selectedEditorTab == MenuEditorTab.Hours)
            {
                <div class="menu-editor-shell__content">
                    <div class="menu-editor-hours-layout">
                        <section class="admin-card menu-editor-hours-summary-panel">
                            <div class="admin-card__header menu-editor-hours-summary-panel__header">
                                <div>
                                    <h2>Current hour summaries</h2>
                                    <p class="admin-field-note menu-editor-hours-summary-panel__intro">Compare the grouped guest-facing hours here, then pick any service card to jump straight into that editor.</p>
                                </div>
                                <div class="menu-editor-hours-summary-panel__badges">
                                    <span class="admin-card__badge">@HoursSummaryCards.Count service@(HoursSummaryCards.Count == 1 ? string.Empty : "s")</span>
                                    <span class="admin-card__badge menu-editor-hours-summary-panel__active-badge">Editing @GetTabLabel(serviceWindowForm.Tab)</span>
                                </div>
                            </div>

                            <div class="menu-editor-hours-summaries">
                                @foreach (var hourCard in HoursSummaryCards)
                                {
                                    <button type="button"
                                            class="menu-editor-hours-summary @(serviceWindowForm.Tab == hourCard.Tab ? "is-selected" : null)"
                                            @onclick="() => SelectHoursTabAsync(hourCard.Tab)">
                                        <span class="menu-editor-hours-summary__header">
                                            <span class="menu-editor-hours-summary__service">
                                                <span class="menu-editor-hours-summary__eyebrow">Guest-facing service</span>
                                                <span class="menu-editor-hours-summary__title">@GetTabLabel(hourCard.Tab)</span>
                                            </span>
                                            <span class="menu-editor-hours-summary__state-badge">@(serviceWindowForm.Tab == hourCard.Tab ? "Editing" : "Click to edit")</span>
                                        </span>

                                        <span class="menu-editor-hours-summary__rows">
                                            @foreach (var row in hourCard.Card.Rows)
                                            {
                                                <span class="menu-editor-hours-summary__row @(row.IncludesToday ? "is-today" : null)">
                                                    <span class="menu-editor-hours-summary__row-copy">@row.Label</span>
                                                    <strong>@row.Summary</strong>
                                                </span>
                                            }
                                        </span>
                                    </button>
                                }
                            </div>
                        </section>

                        <section class="admin-card menu-editor-hours-detail-panel">
                            <div class="admin-card__header">
                                <h2>Edit @GetTabLabel(serviceWindowForm.Tab) hours</h2>
                                <span class="admin-card__badge">@HoursEditorStateLabel</span>
                            </div>

                            <div class="menu-hours-tab-row">
                                @foreach (var tab in HourTabs.OrderBy(tab => tab.Tab))
                                {
                                    <button type="button"
                                            class="action-button @(serviceWindowForm.Tab == tab.Tab ? "action-button--primary" : "action-button--secondary")"
                                            @onclick="() => SelectHoursTabAsync(tab.Tab)">
                                        @tab.Label
                                    </button>
                                }
                            </div>

                            <div class="menu-hours-editor" @key="serviceWindowForm.Tab">
                                @foreach (var day in serviceWindowForm.Days)
                                {
                                    <div class="menu-hours-editor__row" @key="(serviceWindowForm.Tab, day.DayOfWeek)">
                                        <div class="menu-hours-editor__day">
                                            <strong>@GetDayLabel(day.DayOfWeek)</strong>
                                        </div>
                                        <label class="menu-hours-editor__toggle">
                                            <span>Available</span>
                                            <input type="checkbox" @bind="day.IsAvailable" />
                                        </label>
                                        <div>
                                            <label for="@GetHoursInputId(day.DayOfWeek, "open")">Open</label>
                                            <InputTimeComboBox Id="@GetHoursInputId(day.DayOfWeek, "open")"
                                                               @bind-Value="day.OpensAtText"
                                                               Placeholder="Type 1300 or pick a time"
                                                               ToggleAriaLabel="@($"Show {GetDayLabel(day.DayOfWeek)} opening times")"
                                                               Disabled="@(!day.IsAvailable)" />
                                        </div>
                                        <div>
                                            <label for="@GetHoursInputId(day.DayOfWeek, "close")">Close</label>
                                            <InputTimeComboBox Id="@GetHoursInputId(day.DayOfWeek, "close")"
                                                               @bind-Value="day.ClosesAtText"
                                                               Placeholder="Type 1300 or pick a time"
                                                               ToggleAriaLabel="@($"Show {GetDayLabel(day.DayOfWeek)} closing times")"
                                                               Disabled="@(!day.IsAvailable)" />
                                        </div>
                                        <label class="menu-hours-editor__toggle">
                                            <span>Closes next day</span>
                                            <input type="checkbox" @bind="day.ClosesNextDay" disabled="@(!day.IsAvailable)" />
                                        </label>
                                    </div>
                                }
                            </div>

                            <div class="action-row action-row--wrap">
                                <button type="button"
                                        class="action-button action-button--primary"
                                        disabled="@(!CanSaveHours)"
                                        @onclick="SaveServiceHoursAsync">
                                    Save @GetTabLabel(serviceWindowForm.Tab) hours
                                </button>
                                <button type="button" class="action-button action-button--secondary" @onclick="() => ResetHoursForm(serviceWindowForm.Tab)">
                                    Revert changes
                                </button>
                            </div>

                            <p class="admin-field-note">Type shorthand like <code>1300</code>, <code>930</code>, or <code>1pm</code>, or open the list for a nearby half-hour pick. Save stays disabled until every available day has valid opening and closing times. Use <strong>Closes next day</strong> when the tab stays open past midnight.</p>
                        </section>

                        <aside class="admin-card menu-editor-guide menu-editor-hours-guide" aria-label="How to use the hours editor">
                            <div class="admin-card__header">
                                <h2>How to use this page</h2>
                                <span class="admin-card__badge">Hours guide</span>
                            </div>

                            <div class="menu-editor-guide__content">
                                <section class="menu-editor-guide__section">
                                    <p class="menu-editor-guide__eyebrow">1. Review the summaries</p>
                                    <p>Use the hour summary cards to scan each menu tab before editing. Click any card to jump straight into that service without hunting through the smaller tab buttons first.</p>
                                </section>

                                <section class="menu-editor-guide__section">
                                    <p class="menu-editor-guide__eyebrow">2. Pick the tab you want</p>
                                    <p>Select Breakfast, Lunch, Dinner, or Drinks before editing. The editor only saves the tab that is currently active.</p>
                                </section>

                                <section class="menu-editor-guide__section">
                                    <p class="menu-editor-guide__eyebrow">3. Mark availability first</p>
                                    <p>Turn <strong>Available</strong> on only for the days that service should run. Unavailable days stay out of the public hours list automatically.</p>
                                </section>

                                <section class="menu-editor-guide__section">
                                    <p class="menu-editor-guide__eyebrow">4. Type or pick times</p>
                                    <p>Use shorthand like <code>1300</code> or <code>1pm</code>, or open the time list for a nearby half-hour pick. Use <strong>Closes next day</strong> when a service crosses midnight.</p>
                                </section>

                                <section class="menu-editor-guide__section">
                                    <p class="menu-editor-guide__eyebrow">5. Save when the state is valid</p>
                                    <p>The save button stays disabled until every available day has both a valid opening and closing time. Save once the card shows the tab is ready.</p>
                                </section>
                            </div>
                        </aside>
                    </div>
                </div>
            }
            else
            {
                <div class="menu-editor-shell__content">
                    <div class="menu-editor-workspace">
                <section class="admin-card menu-editor-browser">
                    <div class="admin-card__header">
                        <h2>@CurrentWorkspaceLabel browser</h2>
                        <span class="admin-card__badge">@BrowserSections.Count section@(BrowserSections.Count == 1 ? string.Empty : "s")</span>
                    </div>

                    @if (selectedEditorTab == MenuEditorTab.Food)
                    {
                        <div class="menu-editor-filters">
                            <p class="menu-editor-filters__label">Meal filter</p>
                            <div class="chip-list">
                                <button type="button" class="@GetFoodFilterClass(null)" @onclick="() => SelectFoodFilter(null)">All</button>
                                <button type="button" class="@GetFoodFilterClass(MenuTab.Breakfast)" @onclick="() => SelectFoodFilter(MenuTab.Breakfast)">Breakfast</button>
                                <button type="button" class="@GetFoodFilterClass(MenuTab.Lunch)" @onclick="() => SelectFoodFilter(MenuTab.Lunch)">Lunch</button>
                                <button type="button" class="@GetFoodFilterClass(MenuTab.Dinner)" @onclick="() => SelectFoodFilter(MenuTab.Dinner)">Dinner</button>
                            </div>
                        </div>
                    }

                    <div class="menu-editor-filters">
                        <p class="menu-editor-filters__label">Content filter</p>
                        <div class="chip-list">
                            <button type="button" class="@GetContentFilterClass(MenuContentFilter.All)" @onclick="() => SetContentFilter(MenuContentFilter.All)">All</button>
                            <button type="button" class="@GetContentFilterClass(MenuContentFilter.Standard)" @onclick="() => SetContentFilter(MenuContentFilter.Standard)">Standard</button>
                            <button type="button" class="@GetContentFilterClass(MenuContentFilter.Specials)" @onclick="() => SetContentFilter(MenuContentFilter.Specials)">Specials</button>
                        </div>
                    </div>

                    <div class="menu-editor-browser__toolbar">
                        <div class="menu-editor-segmented" role="group" aria-label="Archive filter">
                            <button type="button" class="@GetArchiveFilterClass(MenuArchiveFilter.Active)" @onclick="() => SetArchiveFilter(MenuArchiveFilter.Active)">Active</button>
                            <button type="button" class="@GetArchiveFilterClass(MenuArchiveFilter.Both)" @onclick="() => SetArchiveFilter(MenuArchiveFilter.Both)">Both</button>
                            <button type="button" class="@GetArchiveFilterClass(MenuArchiveFilter.Archived)" @onclick="() => SetArchiveFilter(MenuArchiveFilter.Archived)">Archived</button>
                        </div>

                        <div class="action-row action-row--wrap">
                            <button type="button" class="action-button action-button--primary" @onclick="StartNewSectionForCurrentTab">Add section</button>
                            <button type="button" class="action-button action-button--secondary" disabled="@(!HasItemCreationContext)" @onclick="StartNewItemForCurrentTab">Add item</button>
                            <button type="button" class="action-button action-button--secondary" disabled="@(!HasItemCreationContext)" @onclick="StartNewSpecialItemForCurrentTab">Add special item</button>
                        </div>
                    </div>

                    @if (BrowserSections.Count == 0)
                    {
                        <div class="menu-editor-empty">
                            <h3>No @(CurrentWorkspaceLabel.ToLowerInvariant()) content matches this view yet.</h3>
                            <p>Switch archive modes or create a new section to begin organizing this side of the menu.</p>
                        </div>
                    }
                    else
                    {
                        <div class="menu-editor-tree">
                            @foreach (var browserSection in BrowserSections)
                            {
                                <article class="@GetSectionContainerClass(browserSection)">
                                    <div class="@($"{GetTreeRowClass(MenuAdminDetailKind.Section, browserSection.Section.SectionId, browserSection.Section.IsArchived, browserSection.Section.IsVisibleToGuests)} menu-editor-tree__section-header")"
                                         role="button"
                                         tabindex="0"
                                         aria-expanded="@(IsBrowserSectionExpanded(browserSection.Section.SectionId) ? "true" : "false")"
                                         @onclick="() => ToggleBrowserSection(browserSection.Section)"
                                         @onkeydown="args => HandleBrowserSectionHeaderKeyDown(args, browserSection.Section)"
                                         @onkeydown:preventDefault="true"
                                         draggable="true"
                                         @ondragstart="() => BeginSectionDrag(browserSection.Section)"
                                         @ondragover:preventDefault
                                         @ondrop="() => DropSectionAsync(browserSection.Section)">
                                        <div class="menu-editor-tree__select">
                                            <span class="menu-editor-tree__title">@browserSection.Section.Name</span>
                                            <span class="menu-editor-tree__subtitle">
                                                @GetFamilyLabel(browserSection.Section.Family) section
                                                @if (!string.IsNullOrWhiteSpace(browserSection.Section.ParentSectionName))
                                                {
                                                    <span> | Child of @browserSection.Section.ParentSectionName</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(browserSection.Section.Callout))
                                                {
                                                    <span> | @browserSection.Section.Callout</span>
                                                }
                                            </span>
                                        </div>

                                        <div class="menu-editor-tree__chips">
                                            <span class="chip chip--neutral">Order @browserSection.Section.SortOrder</span>
                                            <span class="chip chip--neutral menu-editor-tree__disclosure">
                                                @(IsBrowserSectionExpanded(browserSection.Section.SectionId) ? "Expanded" : "Collapsed")
                                            </span>
                                            @foreach (var label in browserSection.Section.StatusLabels)
                                            {
                                                <span class="status-pill @(GetStatusClass(label))">@label</span>
                                            }
                                        </div>

                                        <div class="menu-editor-tree__actions">
                                            <button type="button"
                                                    class="menu-editor-tree__icon-button"
                                                    title="Move section up"
                                                    disabled="@(!CanMoveSection(browserSection.Section, -1))"
                                                    @onclick:stopPropagation="true"
                                                    @onkeydown:stopPropagation="true"
                                                    @onclick="() => MoveSectionAsync(browserSection.Section, -1)">
                                                Up
                                            </button>
                                            <button type="button"
                                                    class="menu-editor-tree__icon-button"
                                                    title="Move section down"
                                                    disabled="@(!CanMoveSection(browserSection.Section, 1))"
                                                    @onclick:stopPropagation="true"
                                                    @onkeydown:stopPropagation="true"
                                                    @onclick="() => MoveSectionAsync(browserSection.Section, 1)">
                                                Down
                                            </button>
                                            <button type="button" class="menu-editor-tree__quick-action" @onclick:stopPropagation="true" @onkeydown:stopPropagation="true" @onclick="() => StartNewItemFromSection(browserSection.Section, false)">+ Item</button>
                                            <button type="button" class="menu-editor-tree__quick-action" @onclick:stopPropagation="true" @onkeydown:stopPropagation="true" @onclick="() => StartNewItemFromSection(browserSection.Section, true)">+ Special item</button>
                                        </div>
                                    </div>

                                    @if (IsBrowserSectionExpanded(browserSection.Section.SectionId) && browserSection.ChildSections.Count > 0 && browserSection.Entries.Count > 0)
                                    {
                                        <div class="menu-editor-tree__group menu-editor-tree__group--mixed">
                                            @foreach (var entry in browserSection.Entries)
                                            {
                                                if (entry.ChildSectionEntry is { } childSection)
                                                {
                                                    <div class="@($"{GetTreeRowClass(MenuAdminDetailKind.Section, childSection.Section.SectionId, childSection.Section.IsArchived, childSection.Section.IsVisibleToGuests, childSection.IsContextMuted)} menu-editor-tree__row--subsection")"
                                                         draggable="true"
                                                         @ondragstart="() => BeginSectionDrag(childSection.Section, browserSection.Section.SectionId)"
                                                         @ondragover:preventDefault
                                                         @ondrop="() => DropSectionContentEntryAsync(browserSection.Section.SectionId, entry)">
                                                        <button type="button" class="menu-editor-tree__select" @onclick="() => SelectSection(childSection.Section)">
                                                            <span class="menu-editor-tree__title">@childSection.Section.Name</span>
                                                            <span class="menu-editor-tree__subtitle">
                                                                Child section
                                                                @if (!string.IsNullOrWhiteSpace(childSection.Section.Callout))
                                                                {
                                                                    <span> | @childSection.Section.Callout</span>
                                                                }
                                                            </span>
                                                        </button>

                                                        <div class="menu-editor-tree__chips">
                                                            <span class="chip chip--neutral">Order @entry.SortOrder</span>
                                                            @foreach (var label in childSection.Section.StatusLabels)
                                                            {
                                                                <span class="status-pill @(GetStatusClass(label))">@label</span>
                                                            }
                                                        </div>

                                                        <div class="menu-editor-tree__actions">
                                                            <button type="button"
                                                                    class="menu-editor-tree__icon-button"
                                                                    title="Move subsection up"
                                                                    disabled="@(!CanMoveSectionContentEntry(browserSection.Section.SectionId, entry, -1))"
                                                                    @onclick="() => MoveSectionContentEntryAsync(browserSection.Section.SectionId, entry, -1)">
                                                                Up
                                                            </button>
                                                            <button type="button"
                                                                    class="menu-editor-tree__icon-button"
                                                                    title="Move subsection down"
                                                                    disabled="@(!CanMoveSectionContentEntry(browserSection.Section.SectionId, entry, 1))"
                                                                    @onclick="() => MoveSectionContentEntryAsync(browserSection.Section.SectionId, entry, 1)">
                                                                Down
                                                            </button>
                                                        </div>
                                                    </div>
                                                }
                                                else if (entry.ItemEntry is { } itemEntry)
                                                {
                                                    <div class="@GetTreeRowClass(MenuAdminDetailKind.Item, itemEntry.Item.ItemId, itemEntry.Item.IsArchived, itemEntry.Item.IsVisibleToGuests, itemEntry.IsContextMuted)"
                                                         draggable="true"
                                                         @ondragstart="() => BeginItemDrag(itemEntry)"
                                                         @ondragover:preventDefault
                                                         @ondrop="() => DropSectionContentEntryAsync(browserSection.Section.SectionId, entry)">
                                                        <button type="button" class="menu-editor-tree__select" @onclick="() => SelectItem(itemEntry)">
                                                            <span class="menu-editor-tree__title">@itemEntry.Item.Name</span>
                                                            <span class="menu-editor-tree__subtitle">@GetItemBrowserSubtitle(itemEntry.Item)</span>
                                                        </button>

                                                        <div class="menu-editor-tree__chips">
                                                            <span class="chip chip--neutral">@GetPriceSummary(itemEntry.Item)</span>
                                                            @if (itemEntry.Item.Special is not null)
                                                            {
                                                                <span class="chip chip--info">@itemEntry.Item.Special.BadgeLabel</span>
                                                            }
                                                            @foreach (var label in itemEntry.Item.StatusLabels)
                                                            {
                                                                <span class="status-pill @(GetStatusClass(label))">@label</span>
                                                            }
                                                        </div>

                                                        <div class="menu-editor-tree__actions">
                                                            <button type="button"
                                                                    class="menu-editor-tree__icon-button"
                                                                    title="Move item up"
                                                                    disabled="@(!CanMoveSectionContentEntry(browserSection.Section.SectionId, entry, -1))"
                                                                    @onclick="() => MoveSectionContentEntryAsync(browserSection.Section.SectionId, entry, -1)">
                                                                Up
                                                            </button>
                                                            <button type="button"
                                                                    class="menu-editor-tree__icon-button"
                                                                    title="Move item down"
                                                                    disabled="@(!CanMoveSectionContentEntry(browserSection.Section.SectionId, entry, 1))"
                                                                    @onclick="() => MoveSectionContentEntryAsync(browserSection.Section.SectionId, entry, 1)">
                                                                Down
                                                            </button>
                                                        </div>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                    else if (IsBrowserSectionExpanded(browserSection.Section.SectionId) && browserSection.Items.Count > 0)
                                    {
                                        <div class="menu-editor-tree__group">
                                            <p class="menu-editor-tree__group-label">Items</p>
                                            @foreach (var itemEntry in browserSection.Items)
                                            {
                                                <div class="@GetTreeRowClass(MenuAdminDetailKind.Item, itemEntry.Item.ItemId, itemEntry.Item.IsArchived, itemEntry.Item.IsVisibleToGuests, itemEntry.IsContextMuted)"
                                                     draggable="true"
                                                     @ondragstart="() => BeginItemDrag(itemEntry)"
                                                     @ondragover:preventDefault
                                                     @ondrop="() => DropItemAsync(itemEntry)">
                                                    <button type="button" class="menu-editor-tree__select" @onclick="() => SelectItem(itemEntry)">
                                                        <span class="menu-editor-tree__title">@itemEntry.Item.Name</span>
                                                        <span class="menu-editor-tree__subtitle">@GetItemBrowserSubtitle(itemEntry.Item)</span>
                                                    </button>

                                                    <div class="menu-editor-tree__chips">
                                                        <span class="chip chip--neutral">@GetPriceSummary(itemEntry.Item)</span>
                                                        @if (itemEntry.Item.Special is not null)
                                                        {
                                                            <span class="chip chip--info">@itemEntry.Item.Special.BadgeLabel</span>
                                                        }
                                                        @foreach (var label in itemEntry.Item.StatusLabels)
                                                        {
                                                            <span class="status-pill @(GetStatusClass(label))">@label</span>
                                                        }
                                                    </div>

                                                    <div class="menu-editor-tree__actions">
                                                        <button type="button"
                                                                class="menu-editor-tree__icon-button"
                                                                title="Move item up"
                                                                disabled="@(!CanMoveItem(itemEntry, -1))"
                                                                @onclick="() => MoveItemAsync(itemEntry, -1)">
                                                            Up
                                                        </button>
                                                        <button type="button"
                                                                class="menu-editor-tree__icon-button"
                                                                title="Move item down"
                                                                disabled="@(!CanMoveItem(itemEntry, 1))"
                                                                @onclick="() => MoveItemAsync(itemEntry, 1)">
                                                            Down
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </article>
                            }
                        </div>
                    }
                </section>

                <section class="admin-card menu-editor-detail">
                    <div class="admin-card__header">
                        <h2>@CurrentDetailTitle</h2>
                        <span class="admin-card__badge">@(CurrentDetailHasUnsavedChanges ? "Unsaved changes" : "Saved state")</span>
                    </div>

                    @if (detailKind == MenuAdminDetailKind.None)
                    {
                        <div class="menu-editor-empty">
                            <h3>Select a section or item to edit it.</h3>
                            <p>The browser stays on the left so staff can scan structure first, then use the detail panel for explicit saves.</p>
                        </div>
                    }
                    else if (detailKind == MenuAdminDetailKind.Section)
                    {
                        <div class="editor-form">
                            <div class="editor-form__grid">
                                <label>
                                    <span>Section name</span>
                                    <CommitAwareInputText @bind-Value="sectionForm.Name" placeholder="Appetizers, Wings, Cocktails..." />
                                </label>

                                <label class="editor-form__message">
                                    <span>Section callout (optional)</span>
                                    <CommitAwareTextArea @bind-Value="sectionForm.Callout"
                                                         placeholder="Includes choice of Bloody Mary or Screwdriver"></CommitAwareTextArea>
                                </label>

                                <label>
                                    <span>Family</span>
                                    <select value="@sectionForm.Family" @onchange="HandleSectionFamilyChangedAsync">
                                        <option value="@MenuFamily.Food">Food</option>
                                        <option value="@MenuFamily.Drink">Drink</option>
                                    </select>
                                </label>

                                <label>
                                    <span>Parent section (optional)</span>
                                    <select @bind="sectionForm.ParentSectionId">
                                        <option value="">No parent section</option>
                                        @foreach (var parentSection in ParentSectionOptions)
                                        {
                                            <option value="@parentSection.SectionId">@parentSection.Name</option>
                                        }
                                    </select>
                                </label>

                                <div class="editor-form__message">
                                    <span>Default menu visibility</span>
                                    <div class="chip-list">
                                        @if (sectionForm.Family == MenuFamily.Food)
                                        {
                                            <button type="button" class="@GetChoiceChipClass(sectionForm.ShowBreakfast)" @onclick="() => ToggleSectionTabAsync(MenuTab.Breakfast)">Breakfast</button>
                                            <button type="button" class="@GetChoiceChipClass(sectionForm.ShowLunch)" @onclick="() => ToggleSectionTabAsync(MenuTab.Lunch)">Lunch</button>
                                            <button type="button" class="@GetChoiceChipClass(sectionForm.ShowDinner)" @onclick="() => ToggleSectionTabAsync(MenuTab.Dinner)">Dinner</button>
                                        }
                                        else
                                        {
                                            <button type="button" class="@GetChoiceChipClass(sectionForm.ShowDrinks)" @onclick="() => ToggleSectionTabAsync(MenuTab.Drinks)">Drinks</button>
                                        }
                                    </div>
                                </div>

                                <label>
                                    <span>Sort order</span>
                                    <input type="number" @bind="sectionForm.SortOrder" />
                                </label>

                                <div class="editor-form__message">
                                    <span>Guest visibility</span>
                                    <div class="chip-list">
                                        <button type="button" class="@GetChoiceChipClass(sectionForm.IsVisibleToGuests)" @onclick="() => sectionForm.IsVisibleToGuests = !sectionForm.IsVisibleToGuests">
                                            @(sectionForm.IsVisibleToGuests ? "Visible to guests" : "Hidden from guests")
                                        </button>
                                    </div>
                                    <p class="admin-field-note">Guests only see sections that currently have visible items. Newly created empty sections still stay visible here so you can keep building them out.</p>
                                </div>

                                <div class="editor-form__message">
                                    <span>Archive state</span>
                                    <div class="chip-list">
                                        <button type="button" class="@GetChoiceChipClass(sectionForm.IsArchived)" @onclick="() => sectionForm.IsArchived = !sectionForm.IsArchived">
                                            @(sectionForm.IsArchived ? "Archived" : "Active")
                                        </button>
                                    </div>
                                    <p class="admin-field-note">Archived sections stay stored for later reuse. They remain hidden from guests.</p>
                                </div>
                            </div>

                            @if (pendingSectionDeleteId == sectionForm.SectionId)
                            {
                                <p class="admin-field-note">Click delete again to permanently remove this section. Sections with dependent items cannot be deleted until those items are moved or removed.</p>
                            }

                            <div class="action-row action-row--wrap">
                                <button type="button" class="action-button action-button--primary" @onclick="SaveSectionAsync">
                                    @(sectionForm.SectionId is null ? "Create section" : "Save section")
                                </button>
                                <button type="button" class="action-button action-button--secondary" @onclick="ResetCurrentDetail">
                                    @(sectionForm.SectionId is null ? "Clear section form" : "Revert changes")
                                </button>
                                @if (sectionForm.SectionId is Guid sectionId)
                                {
                                    <button type="button"
                                            class="action-button action-button--secondary"
                                            disabled="@sectionForm.IsArchived"
                                            @onclick="() => ArchiveSectionAsync(sectionId)">
                                        Archive section
                                    </button>
                                    <button type="button" class="action-button action-button--danger" @onclick="() => ToggleSectionDeleteAsync(sectionId)">
                                        @(pendingSectionDeleteId == sectionId ? "Confirm delete section" : "Delete section")
                                    </button>
                                }
                            </div>
                        </div>
                    }
                    else if (detailKind == MenuAdminDetailKind.Item)
                    {
                        <div class="editor-form">
                            <div class="editor-form__grid">
                                <div class="editor-form__message">
                                    <span>Sections</span>
                                    <div class="chip-list">
                                        @foreach (var section in ItemSectionOptions)
                                        {
                                            <button type="button"
                                                    class="@GetChoiceChipClass(itemForm.SelectedSectionIds.Contains(section.SectionId))"
                                                    @onclick="args => HandleItemSectionSelectionChangedAsync(section.SectionId, new ChangeEventArgs { Value = !itemForm.SelectedSectionIds.Contains(section.SectionId) })">
                                                @section.Name
                                            </button>
                                        }
                                    </div>
                                </div>

                                <label>
                                    <span>Sort order</span>
                                    <input type="number" @bind="itemForm.SortOrder" @bind:after="HandleItemSortOrderChangedAsync" />
                                </label>

                                <label>
                                    <span>Name</span>
                                    <CommitAwareInputText @bind-Value="itemForm.Name"
                                                         OnBlur="HandleItemNameBlurAsync"
                                                         placeholder="Classic hamburger, wing night, old fashioned..." />
                                </label>

                                @if (DuplicateItemPrompt is not null)
                                {
                                    <div class="editor-form__message">
                                        <p class="admin-field-note">
                                            A menu item named <strong>@DuplicateItemPrompt.Name</strong> already exists.
                                            Would you like to edit the existing item instead?
                                        </p>
                                        <div class="action-row action-row--wrap">
                                            <button type="button" class="action-button action-button--secondary" @onclick="EditExistingDuplicateItem">
                                                Edit existing item
                                            </button>
                                            <button type="button" class="action-button action-button--secondary" @onclick="DismissDuplicateItemPrompt">
                                                Keep typing
                                            </button>
                                        </div>
                                    </div>
                                }

                                <label>
                                    <span>Image path or URL</span>
                                    <CommitAwareInputText @bind-Value="itemForm.ImagePath" placeholder="/images/menu/wings.jpg" />
                                </label>

                                <label class="editor-form__message">
                                    <span>Description (optional)</span>
                                    <CommitAwareTextArea @bind-Value="itemForm.Description"
                                                         placeholder="Optional. Describe what guests should know about this item."></CommitAwareTextArea>
                                </label>

                                <div class="editor-form__message">
                                    <span>Price variants</span>
                                    <div class="menu-editor-price-list">
                                        @foreach (var variant in itemForm.PriceVariants)
                                        {
                                            <div class="menu-editor-price-row">
                                                <label>
                                                    <span>Label</span>
                                                    <CommitAwareInputText @bind-Value="variant.Label" placeholder="Regular, Basket, Single..." />
                                                </label>
                                                <label>
                                                    <span>Amount</span>
                                                    <CommitAwareInputText @bind-Value="variant.AmountText" placeholder="9.00" />
                                                </label>
                                                <button type="button"
                                                        class="menu-editor-tree__icon-button"
                                                        disabled="@(itemForm.PriceVariants.Count == 1)"
                                                        @onclick="() => RemovePriceVariant(variant)">
                                                    Remove
                                                </button>
                                            </div>
                                        }
                                    </div>
                                    <button type="button" class="action-button action-button--secondary" @onclick="AddPriceVariant">Add price variant</button>
                                </div>

                                @if (GetItemEditorFamily() == MenuFamily.Food)
                                {
                                    <div class="editor-form__message">
                                        <span>Menu visibility mode</span>
                                        <div class="chip-list">
                                            <button type="button" class="@GetChoiceChipClass(itemForm.UseSectionVisibility)" @onclick="() => SetItemUseSectionVisibilityAsync(true)">Use section defaults</button>
                                            <button type="button" class="@GetChoiceChipClass(!itemForm.UseSectionVisibility)" @onclick="() => SetItemUseSectionVisibilityAsync(false)">Override item menus</button>
                                        </div>
                                        <p class="admin-field-note">Turn section defaults off only when this specific item should appear on fewer menus than its assigned sections.</p>
                                    </div>

                                    <div class="editor-form__message">
                                        <span>Item menu visibility</span>
                                        <div class="chip-list">
                                            <button type="button" class="@GetChoiceChipClass(itemForm.ShowBreakfast, itemForm.UseSectionVisibility)" disabled="@itemForm.UseSectionVisibility" @onclick="() => ToggleItemMenuTabAsync(MenuTab.Breakfast)">Breakfast</button>
                                            <button type="button" class="@GetChoiceChipClass(itemForm.ShowLunch, itemForm.UseSectionVisibility)" disabled="@itemForm.UseSectionVisibility" @onclick="() => ToggleItemMenuTabAsync(MenuTab.Lunch)">Lunch</button>
                                            <button type="button" class="@GetChoiceChipClass(itemForm.ShowDinner, itemForm.UseSectionVisibility)" disabled="@itemForm.UseSectionVisibility" @onclick="() => ToggleItemMenuTabAsync(MenuTab.Dinner)">Dinner</button>
                                        </div>
                                    </div>
                                }

                                <div class="editor-form__message">
                                    <span>Guest visibility</span>
                                    <div class="chip-list">
                                        <button type="button" class="@GetChoiceChipClass(itemForm.IsVisibleToGuests)" @onclick="() => itemForm.IsVisibleToGuests = !itemForm.IsVisibleToGuests">
                                            @(itemForm.IsVisibleToGuests ? "Visible to guests" : "Hidden from guests")
                                        </button>
                                    </div>
                                    <p class="admin-field-note">Hidden items stay in the editor but do not show on the public menu.</p>
                                </div>

                                <div class="editor-form__message">
                                    <span>Archive state</span>
                                    <div class="chip-list">
                                        <button type="button" class="@GetChoiceChipClass(itemForm.IsArchived)" @onclick="() => itemForm.IsArchived = !itemForm.IsArchived">
                                            @(itemForm.IsArchived ? "Archived" : "Active")
                                        </button>
                                    </div>
                                    <p class="admin-field-note">Archived items stay stored for future reuse and appear greyed out in the browser.</p>
                                </div>

                                <div class="editor-form__message">
                                    <span>Item type</span>
                                    <div class="chip-list">
                                        <button type="button" class="@GetChoiceChipClass(!itemForm.IsSpecial)" @onclick="() => HandleSpecialToggleChangedAsync(new ChangeEventArgs { Value = false })">Standard item</button>
                                        <button type="button" class="@GetChoiceChipClass(itemForm.IsSpecial)" @onclick="() => HandleSpecialToggleChangedAsync(new ChangeEventArgs { Value = true })">Special item</button>
                                    </div>
                                    <p class="admin-field-note">Shared item fields stay here. Turn on special mode when the item needs recurring or dated special scheduling.</p>
                                </div>

                                <label>
                                    <span>Offer start date</span>
                                    <CommitAwareInputText @bind-Value="itemForm.OfferStartsOnText" placeholder="YYYY-MM-DD" />
                                </label>

                                <label>
                                    <span>Offer end date</span>
                                    <CommitAwareInputText @bind-Value="itemForm.OfferEndsOnText" placeholder="YYYY-MM-DD" />
                                </label>

                                @if (!itemForm.IsSpecial)
                                {
                                    <div class="editor-form__message">
                                        <span>Seasonal presentation</span>
                                        <div class="chip-list">
                                            <button type="button" class="@GetChoiceChipClass(itemForm.IsSeasonal)" @onclick="() => itemForm.IsSeasonal = !itemForm.IsSeasonal">Seasonal badge for dated offer</button>
                                        </div>
                                        <p class="admin-field-note">Use this when a normal dated item should show a seasonal badge while its lifetime window is active.</p>
                                    </div>
                                }

                                <div class="editor-form__message">
                                    <span>Recurring seasonal availability</span>
                                    <div class="chip-list">
                                        <button type="button" class="@GetChoiceChipClass(itemForm.UseRecurringSeasonWindow)" @onclick="() => SetRecurringSeasonWindowEnabledAsync(true)">Enable recurring season</button>
                                        <button type="button" class="@GetChoiceChipClass(!itemForm.UseRecurringSeasonWindow)" @onclick="() => SetRecurringSeasonWindowEnabledAsync(false)">No recurring season</button>
                                    </div>

                                    @if (itemForm.UseRecurringSeasonWindow)
                                    {
                                        <div class="editor-form__grid menu-editor-season-grid">
                                            <label>
                                                <span>Start month</span>
                                                <select @bind="itemForm.SeasonStartMonth">
                                                    <option value=""></option>
                                                    @foreach (var month in MonthOptions)
                                                    {
                                                        <option value="@month.Value">@month.Label</option>
                                                    }
                                                </select>
                                            </label>

                                            <label>
                                                <span>Start day (optional)</span>
                                                <input type="number" min="1" max="@GetMaxDayForMonth(itemForm.SeasonStartMonth, true)" @bind="itemForm.SeasonStartDay" />
                                            </label>

                                            <label>
                                                <span>End month</span>
                                                <select @bind="itemForm.SeasonEndMonth">
                                                    <option value=""></option>
                                                    @foreach (var month in MonthOptions)
                                                    {
                                                        <option value="@month.Value">@month.Label</option>
                                                    }
                                                </select>
                                            </label>

                                            <label>
                                                <span>End day (optional)</span>
                                                <input type="number" min="1" max="@GetMaxDayForMonth(itemForm.SeasonEndMonth, false)" @bind="itemForm.SeasonEndDay" placeholder="Last day of month" />
                                            </label>
                                        </div>
                                    }
                                </div>

                                @if (itemForm.IsSpecial)
                                {
                                    <div class="editor-form__message menu-editor-special-settings">
                                        <div class="admin-card__header">
                                            <h3>Special settings</h3>
                                            <span class="admin-card__badge">Item extension</span>
                                        </div>

                                        <div class="editor-form__grid">
                                            <label>
                                                <span>Schedule type</span>
                                                <select @bind="itemForm.SpecialScheduleKind">
                                                    <option value="@MenuItemSpecialScheduleKind.WeeklyRecurring">Weekly recurring</option>
                                                    <option value="@MenuItemSpecialScheduleKind.Dated">Dated</option>
                                                </select>
                                            </label>

                                            @if (itemForm.SpecialScheduleKind == MenuItemSpecialScheduleKind.WeeklyRecurring)
                                            {
                                                <div class="editor-form__message">
                                                    <span>Recurring weekdays</span>
                                                    <div class="chip-list">
                                                        @foreach (var day in OrderedDays)
                                                        {
                                                            <button type="button"
                                                                    class="@GetChoiceChipClass(itemForm.SelectedSpecialDays.Contains(day))"
                                                                    @onclick="() => ToggleSpecialDayAsync(day)">
                                                                @GetDayLabel(day)
                                                            </button>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <label>
                                                    <span>Start date</span>
                                                    <CommitAwareInputText @bind-Value="itemForm.SpecialStartDateText" placeholder="YYYY-MM-DD" />
                                                </label>

                                                <label>
                                                    <span>End date</span>
                                                    <CommitAwareInputText @bind-Value="itemForm.SpecialEndDateText" placeholder="YYYY-MM-DD" />
                                                </label>
                                            }

                                            <div>
                                                <label for="special-start-time">Start time</label>
                                                <InputTimeComboBox Id="special-start-time"
                                                                   @bind-Value="itemForm.SpecialStartsAtText"
                                                                   Placeholder="Optional"
                                                                   ToggleAriaLabel="Show special start times" />
                                            </div>

                                            <div>
                                                <label for="special-end-time">End time</label>
                                                <InputTimeComboBox Id="special-end-time"
                                                                   @bind-Value="itemForm.SpecialEndsAtText"
                                                                   Placeholder="Optional"
                                                                   ToggleAriaLabel="Show special end times" />
                                            </div>

                                            <div class="editor-form__message">
                                                <span>Time handling</span>
                                                <div class="chip-list">
                                                    <button type="button" class="@GetChoiceChipClass(itemForm.SpecialClosesNextDay)" @onclick="() => itemForm.SpecialClosesNextDay = !itemForm.SpecialClosesNextDay">Closes next day</button>
                                                </div>
                                                <p class="admin-field-note">Use this when a special starts late and ends after midnight.</p>
                                            </div>

                                            <label class="editor-form__message">
                                                <span>Short callout</span>
                                                <CommitAwareInputText @bind-Value="itemForm.SpecialCallout" placeholder="After 5 PM, while supplies last, bar-only..." />
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>

                            @if (itemForm.ItemId is Guid existingItemId && pendingItemDeleteId == existingItemId)
                            {
                                <p class="admin-field-note">Click delete again to permanently remove this item. Special items are deleted as a whole item record together with their special extension.</p>
                            }

                            <StatusMessage Message="@DetailStatusMessage" />

                            <div class="action-row action-row--wrap">
                                <button type="button" class="action-button action-button--primary" @onclick="SaveItemAsync">
                                    @(itemForm.ItemId is null ? (itemForm.IsSpecial ? "Create special item" : "Create item") : (itemForm.IsSpecial ? "Save special item" : "Save item"))
                                </button>
                                <button type="button" class="action-button action-button--secondary" @onclick="ResetCurrentDetail">
                                    @(itemForm.ItemId is null ? (itemForm.IsSpecial ? "Clear special form" : "Clear item form") : "Revert changes")
                                </button>
                                @if (itemForm.ItemId is Guid itemId)
                                {
                                    <button type="button"
                                            class="action-button action-button--secondary"
                                            disabled="@itemForm.IsArchived"
                                            @onclick="() => ArchiveItemAsync(itemId)">
                                        Archive item
                                    </button>
                                    <button type="button" class="action-button action-button--danger" @onclick="() => ToggleItemDeleteAsync(itemId)">
                                        @(pendingItemDeleteId == itemId ? "Confirm delete item" : "Delete item")
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </section>

                <aside class="admin-card menu-editor-guide" aria-label="How to use the menu editor">
                    <div class="admin-card__header">
                        <h2>How to use this page</h2>
                        <span class="admin-card__badge">Quick guide</span>
                    </div>

                    <div class="menu-editor-guide__content">
                        <section class="menu-editor-guide__section">
                            <p class="menu-editor-guide__eyebrow">1. Browse the catalog</p>
                            <p>Use the meal, content, and archive filters on the left to narrow the current workspace before you edit anything.</p>
                        </section>

                        <section class="menu-editor-guide__section">
                            <p class="menu-editor-guide__eyebrow">2. Order sections and subsections</p>
                            <p>Parent section cards show one mixed list of direct items and child subsection headers so you can move them around each other in the same order stream.</p>
                        </section>

                        <section class="menu-editor-guide__section">
                            <p class="menu-editor-guide__eyebrow">3. Edit from the center panel</p>
                            <p>Select a section or item to load it into the detail pane, make your changes, then use the explicit save button at the bottom of that form. Turn on <strong>Is special</strong> only when that item needs the extra special schedule controls.</p>
                        </section>

                        <section class="menu-editor-guide__section">
                            <p class="menu-editor-guide__eyebrow">4. Create in context</p>
                            <p>Choose a section first when you can. The top toolbar uses the current selection so new items and special items start in the right place.</p>
                        </section>

                        <section class="menu-editor-guide__section">
                            <p class="menu-editor-guide__eyebrow">5. Visibility and duplicates</p>
                            <p>Sections can control their default menu visibility, and items can either follow those defaults or narrow them. If a typed item name already exists, the editor offers to switch into that record instead of saving a duplicate.</p>
                        </section>

                        <section class="menu-editor-guide__section">
                            <p class="menu-editor-guide__eyebrow">6. Use archive before delete</p>
                            <p>Archive is the safe way to hide something from guests while keeping it ready for reuse. Delete is permanent and always requires confirmation.</p>
                        </section>
                    </div>
                </aside>
                    </div>
                </div>
            }
        </div>
    }
</section>
