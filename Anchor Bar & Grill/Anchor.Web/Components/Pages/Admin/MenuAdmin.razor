@page "/admin/menu"
@using Anchor.Domain.Identity
@using Anchor.Domain.Menu
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Policy = ApplicationPolicies.MenuManagement)]

<PageTitle>Menu Editor</PageTitle>

<section class="admin-page menu-admin-page">
    <div class="page-hero page-hero--section">
        <p class="page-hero__eyebrow">Menu Management</p>
        <h1>Menu editor</h1>
        <p class="page-hero__lead">
            Manage fixed public tabs from a browser-style editor. Hours stay in their own workspace, while
            Food and Drinks each use a section tree plus detail panel so staff can review live content before
            saving changes.
        </p>
    </div>

    <StatusMessage Message="@statusMessage" />

    @if (isLoading || menuView is null)
    {
        <section class="admin-card">
            <div class="admin-card__header">
                <h2>Loading menu data</h2>
                <span class="admin-card__badge">Please wait</span>
            </div>
            <p class="admin-field-note">Pulling the latest sections, items, recurring specials, and service hours from the catalog.</p>
        </section>
    }
    else
    {
        <section class="admin-card menu-editor-intro">
            <div class="menu-editor-tabs" role="tablist" aria-label="Menu editor workspaces">
                <button type="button"
                        role="tab"
                        class="@GetEditorTabClass(MenuEditorTab.Food)"
                        aria-selected="@(selectedEditorTab == MenuEditorTab.Food)"
                        @onclick="() => SelectEditorTab(MenuEditorTab.Food)">
                    Food
                </button>
                <button type="button"
                        role="tab"
                        class="@GetEditorTabClass(MenuEditorTab.Drinks)"
                        aria-selected="@(selectedEditorTab == MenuEditorTab.Drinks)"
                        @onclick="() => SelectEditorTab(MenuEditorTab.Drinks)">
                    Drinks
                </button>
                <button type="button"
                        role="tab"
                        class="@GetEditorTabClass(MenuEditorTab.Hours)"
                        aria-selected="@(selectedEditorTab == MenuEditorTab.Hours)"
                        @onclick="() => SelectEditorTab(MenuEditorTab.Hours)">
                    Hours
                </button>
            </div>

            <div class="menu-editor-intro__copy">
                <h2>@(selectedEditorTab == MenuEditorTab.Hours ? "Hours workspace" : $"{CurrentWorkspaceLabel} workspace")</h2>
                @if (selectedEditorTab == MenuEditorTab.Hours)
                {
                    <p>
                        Review grouped guest-facing hour summaries for Breakfast, Lunch, Dinner, and Drinks, then open the
                        tab you want to edit with the reusable time combobox fields.
                    </p>
                }
                else if (selectedEditorTab == MenuEditorTab.Food)
                {
                    <p>
                        Browse food sections and menu items together, then manage recurring specials as item-backed offers.
                        Use the meal and content chips to focus the tree without changing the underlying menu assignments.
                    </p>
                }
                else
                {
                    <p>
                        Manage drink sections, beverage items, and recurring specials as one catalog. Archived content stays
                        accessible from the same tree so staff can restore or reuse it later.
                    </p>
                }
                <ul class="menu-editor-intro__list">
                    <li>Archive is the safe removal path. Delete still exists, but it always requires a second confirmation.</li>
                    <li>The tree uses Active, Both, and Archived browsing modes so staff can focus on the right slice of the catalog.</li>
                    <li>Move buttons shift records one slot at a time, drag-and-drop drops into the new slot, and exact sort-order fields remain available in the detail panel.</li>
                </ul>
            </div>
        </section>

        @if (selectedEditorTab == MenuEditorTab.Hours)
        {
            <div class="menu-editor-hours-layout">
                <section class="admin-card">
                    <div class="admin-card__header">
                        <h2>Current hour summaries</h2>
                        <span class="admin-card__badge">@HoursSummaryCards.Count tab@(HoursSummaryCards.Count == 1 ? string.Empty : "s")</span>
                    </div>

                    <div class="menu-editor-hours-summaries">
                        @foreach (var hourCard in HoursSummaryCards)
                        {
                            <article class="menu-editor-hours-summary @(serviceWindowForm.Tab == hourCard.Tab ? "is-selected" : null)">
                                <div class="menu-editor-hours-summary__header">
                                    <div>
                                        <p class="menu-editor-hours-summary__eyebrow">@hourCard.Label</p>
                                        <h3>@GetTabLabel(hourCard.Tab)</h3>
                                    </div>
                                    <button type="button"
                                            class="action-button @(serviceWindowForm.Tab == hourCard.Tab ? "action-button--primary" : "action-button--secondary")"
                                            @onclick="() => SelectHoursTabAsync(hourCard.Tab)">
                                        @(serviceWindowForm.Tab == hourCard.Tab ? "Editing" : "Edit hours")
                                    </button>
                                </div>

                                <p class="menu-editor-hours-summary__today">
                                    <span>Today</span>
                                    <strong>@hourCard.Card.TodaySummary</strong>
                                </p>

                                <div class="menu-editor-hours-summary__rows">
                                    @foreach (var row in hourCard.Card.Rows)
                                    {
                                        <div class="menu-editor-hours-summary__row">
                                            <span>@row.Label</span>
                                            <strong>@row.Summary</strong>
                                        </div>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                </section>

                <section class="admin-card">
                    <div class="admin-card__header">
                        <h2>Edit @GetTabLabel(serviceWindowForm.Tab) hours</h2>
                        <span class="admin-card__badge">@(HoursHaveUnsavedChanges ? "Unsaved changes" : "Saved state")</span>
                    </div>

                    <div class="menu-hours-tab-row">
                        @foreach (var tab in HourTabs.OrderBy(tab => tab.Tab))
                        {
                            <button type="button"
                                    class="action-button @(serviceWindowForm.Tab == tab.Tab ? "action-button--primary" : "action-button--secondary")"
                                    @onclick="() => SelectHoursTabAsync(tab.Tab)">
                                @tab.Label
                            </button>
                        }
                    </div>

                    <div class="menu-hours-editor" @key="serviceWindowForm.Tab">
                        @foreach (var day in serviceWindowForm.Days)
                        {
                            <div class="menu-hours-editor__row" @key="(serviceWindowForm.Tab, day.DayOfWeek)">
                                <div class="menu-hours-editor__day">
                                    <strong>@GetDayLabel(day.DayOfWeek)</strong>
                                </div>
                                <label class="menu-hours-editor__toggle">
                                    <span>Available</span>
                                    <input type="checkbox" @bind="day.IsAvailable" />
                                </label>
                                <div>
                                    <label for="@GetHoursInputId(day.DayOfWeek, "open")">Open</label>
                                    <InputTimeComboBox Id="@GetHoursInputId(day.DayOfWeek, "open")"
                                                       @bind-Value="day.OpensAtText"
                                                       Placeholder="Type 1300 or pick a time"
                                                       ToggleAriaLabel="@($"Show {GetDayLabel(day.DayOfWeek)} opening times")"
                                                       Disabled="@(!day.IsAvailable)" />
                                </div>
                                <div>
                                    <label for="@GetHoursInputId(day.DayOfWeek, "close")">Close</label>
                                    <InputTimeComboBox Id="@GetHoursInputId(day.DayOfWeek, "close")"
                                                       @bind-Value="day.ClosesAtText"
                                                       Placeholder="Type 1300 or pick a time"
                                                       ToggleAriaLabel="@($"Show {GetDayLabel(day.DayOfWeek)} closing times")"
                                                       Disabled="@(!day.IsAvailable)" />
                                </div>
                                <label class="menu-hours-editor__toggle">
                                    <span>Closes next day</span>
                                    <input type="checkbox" @bind="day.ClosesNextDay" disabled="@(!day.IsAvailable)" />
                                </label>
                            </div>
                        }
                    </div>

                    <div class="action-row action-row--wrap">
                        <button type="button" class="action-button action-button--primary" @onclick="SaveServiceHoursAsync">
                            Save @GetTabLabel(serviceWindowForm.Tab) hours
                        </button>
                        <button type="button" class="action-button action-button--secondary" @onclick="() => ResetHoursForm(serviceWindowForm.Tab)">
                            Revert changes
                        </button>
                    </div>

                    <p class="admin-field-note">Type shorthand like <code>1300</code>, <code>930</code>, or <code>1pm</code>, or open the list for a nearby half-hour pick. Use <strong>Closes next day</strong> when the tab stays open past midnight.</p>
                </section>
            </div>
        }
        else
        {
            <div class="menu-editor-workspace">
                <section class="admin-card menu-editor-browser">
                    <div class="admin-card__header">
                        <h2>@CurrentWorkspaceLabel browser</h2>
                        <span class="admin-card__badge">@BrowserSections.Count section@(BrowserSections.Count == 1 ? string.Empty : "s")</span>
                    </div>

                    @if (selectedEditorTab == MenuEditorTab.Food)
                    {
                        <div class="menu-editor-filters">
                            <p class="menu-editor-filters__label">Meal filter</p>
                            <div class="chip-list">
                                <button type="button" class="@GetFoodFilterClass(null)" @onclick="() => SelectFoodFilter(null)">All</button>
                                <button type="button" class="@GetFoodFilterClass(MenuTab.Breakfast)" @onclick="() => SelectFoodFilter(MenuTab.Breakfast)">Breakfast</button>
                                <button type="button" class="@GetFoodFilterClass(MenuTab.Lunch)" @onclick="() => SelectFoodFilter(MenuTab.Lunch)">Lunch</button>
                                <button type="button" class="@GetFoodFilterClass(MenuTab.Dinner)" @onclick="() => SelectFoodFilter(MenuTab.Dinner)">Dinner</button>
                            </div>
                        </div>
                    }

                    <div class="menu-editor-filters">
                        <p class="menu-editor-filters__label">Content filter</p>
                        <div class="chip-list">
                            <button type="button" class="@GetContentFilterClass(MenuContentFilter.All)" @onclick="() => SetContentFilter(MenuContentFilter.All)">All</button>
                            <button type="button" class="@GetContentFilterClass(MenuContentFilter.Standard)" @onclick="() => SetContentFilter(MenuContentFilter.Standard)">Standard</button>
                            <button type="button" class="@GetContentFilterClass(MenuContentFilter.Specials)" @onclick="() => SetContentFilter(MenuContentFilter.Specials)">Specials</button>
                        </div>
                    </div>

                    <div class="menu-editor-browser__toolbar">
                        <div class="menu-editor-segmented" role="group" aria-label="Archive filter">
                            <button type="button" class="@GetArchiveFilterClass(MenuArchiveFilter.Active)" @onclick="() => SetArchiveFilter(MenuArchiveFilter.Active)">Active</button>
                            <button type="button" class="@GetArchiveFilterClass(MenuArchiveFilter.Both)" @onclick="() => SetArchiveFilter(MenuArchiveFilter.Both)">Both</button>
                            <button type="button" class="@GetArchiveFilterClass(MenuArchiveFilter.Archived)" @onclick="() => SetArchiveFilter(MenuArchiveFilter.Archived)">Archived</button>
                        </div>

                        <div class="action-row action-row--wrap">
                            <button type="button" class="action-button action-button--primary" @onclick="StartNewSectionForCurrentTab">Add section</button>
                            <button type="button" class="action-button action-button--secondary" disabled="@(!HasItemCreationContext)" @onclick="StartNewItemForCurrentTab">Add item</button>
                            <button type="button" class="action-button action-button--secondary" disabled="@(!HasSpecialCreationContext)" @onclick="StartNewSpecialForCurrentTab">Add special offer</button>
                        </div>
                    </div>

                    @if (BrowserSections.Count == 0)
                    {
                        <div class="menu-editor-empty">
                            <h3>No @(CurrentWorkspaceLabel.ToLowerInvariant()) content matches this view yet.</h3>
                            <p>Switch archive modes or create a new section to begin organizing this side of the menu.</p>
                        </div>
                    }
                    else
                    {
                        <div class="menu-editor-tree">
                            @foreach (var browserSection in BrowserSections)
                            {
                                <article class="@GetSectionContainerClass(browserSection)">
                                    <div class="@GetTreeRowClass(MenuAdminDetailKind.Section, browserSection.Section.SectionId, browserSection.Section.IsArchived, browserSection.Section.IsVisibleToGuests)"
                                         draggable="true"
                                         @ondragstart="() => BeginSectionDrag(browserSection.Section)"
                                         @ondragover:preventDefault
                                         @ondrop="() => DropSectionAsync(browserSection.Section)">
                                        <button type="button" class="menu-editor-tree__select" @onclick="() => SelectSection(browserSection.Section)">
                                            <span class="menu-editor-tree__title">@browserSection.Section.Name</span>
                                            <span class="menu-editor-tree__subtitle">@GetFamilyLabel(browserSection.Section.Family) section</span>
                                        </button>

                                        <div class="menu-editor-tree__chips">
                                            <span class="chip chip--neutral">Order @browserSection.Section.SortOrder</span>
                                            @foreach (var label in browserSection.Section.StatusLabels)
                                            {
                                                <span class="status-pill @(GetStatusClass(label))">@label</span>
                                            }
                                        </div>

                                        <div class="menu-editor-tree__actions">
                                            <button type="button"
                                                    class="menu-editor-tree__icon-button"
                                                    title="Move section up"
                                                    disabled="@(BrowserSections.First().Section.SectionId == browserSection.Section.SectionId)"
                                                    @onclick="() => MoveSectionAsync(browserSection.Section, -1)">
                                                Up
                                            </button>
                                            <button type="button"
                                                    class="menu-editor-tree__icon-button"
                                                    title="Move section down"
                                                    disabled="@(BrowserSections.Last().Section.SectionId == browserSection.Section.SectionId)"
                                                    @onclick="() => MoveSectionAsync(browserSection.Section, 1)">
                                                Down
                                            </button>
                                            <button type="button" class="menu-editor-tree__quick-action" @onclick="() => StartNewItemFromSection(browserSection.Section)">+ Item</button>
                                            <button type="button" class="menu-editor-tree__quick-action" @onclick="() => StartNewSpecialFromSection(browserSection.Section)">+ Special offer</button>
                                        </div>
                                    </div>

                                    @if (browserSection.Items.Count > 0)
                                    {
                                        <div class="menu-editor-tree__group">
                                            <p class="menu-editor-tree__group-label">Items</p>
                                            @foreach (var itemEntry in browserSection.Items)
                                            {
                                                <div class="@GetTreeRowClass(MenuAdminDetailKind.Item, itemEntry.Item.ItemId, itemEntry.Item.IsArchived, itemEntry.Item.IsVisibleToGuests, itemEntry.IsContextMuted)"
                                                     draggable="true"
                                                     @ondragstart="() => BeginItemDrag(itemEntry.Item)"
                                                     @ondragover:preventDefault
                                                     @ondrop="() => DropItemAsync(itemEntry.Item)">
                                                    <button type="button" class="menu-editor-tree__select" @onclick="() => SelectItem(itemEntry.Item)">
                                                        <span class="menu-editor-tree__title">@itemEntry.Item.Name</span>
                                                        <span class="menu-editor-tree__subtitle">@GetItemTabSummary(itemEntry.Item)</span>
                                                    </button>

                                                    <div class="menu-editor-tree__chips">
                                                        <span class="chip chip--neutral">@GetPriceSummary(itemEntry.Item)</span>
                                                        @if (itemEntry.Specials.Count > 0)
                                                        {
                                                            <span class="chip chip--info">@itemEntry.Specials.Count special@(itemEntry.Specials.Count == 1 ? string.Empty : "s")</span>
                                                        }
                                                        @foreach (var label in itemEntry.Item.StatusLabels)
                                                        {
                                                            <span class="status-pill @(GetStatusClass(label))">@label</span>
                                                        }
                                                    </div>

                                                    <div class="menu-editor-tree__actions">
                                                        <button type="button"
                                                                class="menu-editor-tree__icon-button"
                                                                title="Move item up"
                                                                disabled="@(browserSection.Items.First().Item.ItemId == itemEntry.Item.ItemId)"
                                                                @onclick="() => MoveItemAsync(itemEntry.Item, -1)">
                                                            Up
                                                        </button>
                                                        <button type="button"
                                                                class="menu-editor-tree__icon-button"
                                                                title="Move item down"
                                                                disabled="@(browserSection.Items.Last().Item.ItemId == itemEntry.Item.ItemId)"
                                                                @onclick="() => MoveItemAsync(itemEntry.Item, 1)">
                                                            Down
                                                        </button>
                                                        <button type="button" class="menu-editor-tree__quick-action" @onclick="() => StartNewSpecialFromItem(itemEntry.Item)">+ Offer</button>
                                                    </div>
                                                </div>

                                                @if (itemEntry.Specials.Count > 0)
                                                {
                                                    <div class="menu-editor-tree__group">
                                                        <p class="menu-editor-tree__group-label">Special offers</p>
                                                        @foreach (var special in itemEntry.Specials)
                                                        {
                                                            <div class="@GetTreeRowClass(MenuAdminDetailKind.Special, special.SpecialId, special.IsArchived, special.IsVisibleToGuests)"
                                                                 draggable="true"
                                                                 @ondragstart="() => BeginSpecialDrag(special)"
                                                                 @ondragover:preventDefault
                                                                 @ondrop="() => DropSpecialAsync(special)">
                                                                <button type="button" class="menu-editor-tree__select" @onclick="() => SelectSpecial(special)">
                                                                    <span class="menu-editor-tree__title">@special.Title</span>
                                                                    <span class="menu-editor-tree__subtitle">@GetSpecialSubtitle(special)</span>
                                                                </button>

                                                                <div class="menu-editor-tree__chips">
                                                                    @if (!string.IsNullOrWhiteSpace(special.PriceNote))
                                                                    {
                                                                        <span class="chip chip--neutral">@special.PriceNote</span>
                                                                    }
                                                                    @foreach (var label in special.StatusLabels)
                                                                    {
                                                                        <span class="status-pill @(GetStatusClass(label))">@label</span>
                                                                    }
                                                                </div>

                                                                <div class="menu-editor-tree__actions">
                                                                    <button type="button"
                                                                            class="menu-editor-tree__icon-button"
                                                                            title="Move special up"
                                                                            disabled="@(itemEntry.Specials.First().SpecialId == special.SpecialId)"
                                                                            @onclick="() => MoveSpecialAsync(special, -1)">
                                                                        Up
                                                                    </button>
                                                                    <button type="button"
                                                                            class="menu-editor-tree__icon-button"
                                                                            title="Move special down"
                                                                            disabled="@(itemEntry.Specials.Last().SpecialId == special.SpecialId)"
                                                                            @onclick="() => MoveSpecialAsync(special, 1)">
                                                                        Down
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }

                                    @if (browserSection.DetachedSpecials.Count > 0)
                                    {
                                        <div class="menu-editor-tree__group">
                                            <p class="menu-editor-tree__group-label">Special offers needing an item link</p>
                                            @foreach (var special in browserSection.DetachedSpecials)
                                            {
                                                <div class="@GetTreeRowClass(MenuAdminDetailKind.Special, special.SpecialId, special.IsArchived, special.IsVisibleToGuests)"
                                                     draggable="true"
                                                     @ondragstart="() => BeginSpecialDrag(special)"
                                                     @ondragover:preventDefault
                                                     @ondrop="() => DropSpecialAsync(special)">
                                                    <button type="button" class="menu-editor-tree__select" @onclick="() => SelectSpecial(special)">
                                                        <span class="menu-editor-tree__title">@special.Title</span>
                                                        <span class="menu-editor-tree__subtitle">@GetSpecialSubtitle(special)</span>
                                                    </button>

                                                    <div class="menu-editor-tree__chips">
                                                        <span class="status-pill status-pill--limited">Needs item link</span>
                                                        @foreach (var label in special.StatusLabels)
                                                        {
                                                            <span class="status-pill @(GetStatusClass(label))">@label</span>
                                                        }
                                                    </div>

                                                    <div class="menu-editor-tree__actions">
                                                        <button type="button"
                                                                class="menu-editor-tree__icon-button"
                                                                title="Move special up"
                                                                disabled="@(browserSection.DetachedSpecials.First().SpecialId == special.SpecialId)"
                                                                @onclick="() => MoveSpecialAsync(special, -1)">
                                                            Up
                                                        </button>
                                                        <button type="button"
                                                                class="menu-editor-tree__icon-button"
                                                                title="Move special down"
                                                                disabled="@(browserSection.DetachedSpecials.Last().SpecialId == special.SpecialId)"
                                                                @onclick="() => MoveSpecialAsync(special, 1)">
                                                            Down
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </article>
                            }
                        </div>
                    }
                </section>

                <section class="admin-card menu-editor-detail">
                    <div class="admin-card__header">
                        <h2>@CurrentDetailTitle</h2>
                        @if (detailKind != MenuAdminDetailKind.None)
                        {
                            <span class="admin-card__badge">@(CurrentDetailHasUnsavedChanges ? "Unsaved changes" : "Saved state")</span>
                        }
                    </div>

                    @if (detailKind == MenuAdminDetailKind.None)
                    {
                        <div class="menu-editor-empty">
                            <h3>Select a section, item, or special from the tree.</h3>
                            <p>The detail panel keeps explicit save controls, archive actions, and delete confirmations together so staff can work on one record at a time.</p>
                        </div>
                    }
                    else if (detailKind == MenuAdminDetailKind.Section)
                    {
                        <div class="editor-form__grid">
                            <label>
                                Section name
                                <input type="text" @bind="sectionForm.Name" />
                                <small>Use clear guest-facing names like Appetizers, Burgers, Cocktails, or Draft Beer.</small>
                            </label>
                            <label>
                                Menu family
                                <input type="text" value="@GetFamilyLabel(sectionForm.Family)" disabled />
                                <small>This workspace only manages @(GetFamilyLabel(CurrentContentFamily).ToLowerInvariant()) sections.</small>
                            </label>
                            <label>
                                Sort order
                                <input type="number" @bind="sectionForm.SortOrder" />
                            </label>
                            <label class="editor-form__toggle">
                                <span>Guest visibility</span>
                                <div class="editor-form__toggle-row">
                                    <input type="checkbox" @bind="sectionForm.IsVisibleToGuests" />
                                    <small>Hidden sections stay visible in the editor but do not show to guests.</small>
                                </div>
                            </label>
                            <label class="editor-form__toggle">
                                <span>Archive section</span>
                                <div class="editor-form__toggle-row">
                                    <input type="checkbox" @bind="sectionForm.IsArchived" />
                                    <small>Archived sections remain stored for reuse and disappear from the active guest view.</small>
                                </div>
                            </label>
                        </div>

                        @if (pendingSectionDeleteId == sectionForm.SectionId)
                        {
                            <p class="status-banner status-banner--warning">Delete is armed for this section. Click Delete section again to permanently remove it.</p>
                        }

                        <div class="action-row action-row--wrap">
                            <button type="button" class="action-button action-button--primary" @onclick="SaveSectionAsync">
                                @(sectionForm.SectionId is null ? "Create section" : "Save section")
                            </button>
                            <button type="button" class="action-button action-button--secondary" @onclick="StartNewSectionForCurrentTab">Clear form</button>
                            @if (sectionForm.SectionId is Guid sectionId)
                            {
                                <button type="button" class="action-button action-button--success" @onclick="() => ArchiveSectionAsync(sectionId)">Archive section</button>
                                <button type="button" class="action-button action-button--danger" @onclick="() => ToggleSectionDeleteAsync(sectionId)">
                                    @(pendingSectionDeleteId == sectionId ? "Confirm delete" : "Delete section")
                                </button>
                            }
                        </div>

                        <p class="admin-field-note">Sections anchor the tree, so use them as stable containers and move items or specials beneath them before considering delete.</p>
                    }
                    else if (detailKind == MenuAdminDetailKind.Item)
                    {
                        <div class="editor-form__grid">
                            <label>
                                Section
                                <select value="@itemForm.SectionId" @onchange="HandleItemSectionChangedAsync">
                                    <option value="">Select a section</option>
                                    @foreach (var section in ItemSectionOptions)
                                    {
                                        <option value="@section.SectionId">@section.Name</option>
                                    }
                                </select>
                                <small>Choose the section first so the editor can keep the item inside the correct tree branch.</small>
                            </label>
                            <label>
                                Menu item
                                <input type="text" @bind="itemForm.Name" />
                            </label>
                            <label>
                                Sort order
                                <input type="number" @bind="itemForm.SortOrder" />
                            </label>
                            <label>
                                Menu image path or URL (optional)
                                <input type="text" @bind="itemForm.ImagePath" />
                                <small>Leave blank when the item does not have a photo yet.</small>
                            </label>
                            <label>
                                Offer start date
                                <input type="date" value="@itemForm.OfferStartsOnText" @onchange="args => itemForm.OfferStartsOnText = args.Value?.ToString()" />
                            </label>
                            <label>
                                Offer end date (optional)
                                <input type="date" value="@itemForm.OfferEndsOnText" @onchange="args => itemForm.OfferEndsOnText = args.Value?.ToString()" />
                            </label>
                            <label class="editor-form__toggle">
                                <span>Guest visibility</span>
                                <div class="editor-form__toggle-row">
                                    <input type="checkbox" @bind="itemForm.IsVisibleToGuests" />
                                    <small>Hidden items stay editable and can be restored later.</small>
                                </div>
                            </label>
                            <label class="editor-form__toggle">
                                <span>Archive item</span>
                                <div class="editor-form__toggle-row">
                                    <input type="checkbox" @bind="itemForm.IsArchived" />
                                    <small>Archived items leave the active menu but stay available for reference and reuse.</small>
                                </div>
                            </label>
                            <label class="editor-form__toggle">
                                <span>Seasonal item?</span>
                                <div class="editor-form__toggle-row">
                                    <input type="checkbox" @bind="itemForm.IsSeasonal" />
                                    <small>The guest-facing Seasonal and Limited Time labels are still derived from dates at runtime.</small>
                                </div>
                            </label>
                            <label class="editor-form__message">
                                Description
                                <textarea rows="4" @bind="itemForm.Description"></textarea>
                            </label>
                        </div>

                        <div class="menu-admin-subcard">
                            <div class="admin-card__header">
                                <h3>Guest tabs</h3>
                                <span class="admin-card__badge">Fixed tabs</span>
                            </div>

                            @if (GetItemEditorFamily() == MenuFamily.Drink)
                            {
                                <p class="admin-field-note">Drink items belong to the Drinks tab automatically because they live inside a drink section.</p>
                            }
                            else
                            {
                                <div class="menu-admin-checkbox-grid">
                                    <label class="editor-form__toggle-row">
                                        <input type="checkbox" @bind="itemForm.ShowBreakfast" />
                                        <span>Breakfast</span>
                                    </label>
                                    <label class="editor-form__toggle-row">
                                        <input type="checkbox" @bind="itemForm.ShowLunch" />
                                        <span>Lunch</span>
                                    </label>
                                    <label class="editor-form__toggle-row">
                                        <input type="checkbox" @bind="itemForm.ShowDinner" />
                                        <span>Dinner</span>
                                    </label>
                                </div>
                            }
                        </div>

                        <div class="menu-admin-subcard">
                            <div class="admin-card__header">
                                <h3>Price variants</h3>
                                <span class="admin-card__badge">@itemForm.PriceVariants.Count variant@(itemForm.PriceVariants.Count == 1 ? string.Empty : "s")</span>
                            </div>

                            <div class="menu-admin-price-stack">
                                @foreach (var variant in itemForm.PriceVariants)
                                {
                                    <div class="menu-admin-price-row" @key="variant">
                                        <label>
                                            Label
                                            <input type="text" @bind="variant.Label" />
                                        </label>
                                        <label>
                                            Amount
                                            <input type="number" step="0.01" @bind="variant.AmountText" />
                                        </label>
                                        <label>
                                            Sort order
                                            <input type="number" @bind="variant.SortOrder" />
                                        </label>
                                        <button type="button"
                                                class="action-button action-button--danger"
                                                disabled="@(itemForm.PriceVariants.Count == 1)"
                                                @onclick="() => RemovePriceVariant(variant)">
                                            Remove
                                        </button>
                                    </div>
                                }
                            </div>

                            <div class="action-row">
                                <button type="button" class="action-button action-button--secondary" @onclick="AddPriceVariant">Add another price</button>
                            </div>
                        </div>

                        @if (pendingItemDeleteId == itemForm.ItemId)
                        {
                            <p class="status-banner status-banner--warning">Delete is armed for this item. Click Delete item again to permanently remove it.</p>
                        }

                        <div class="action-row action-row--wrap">
                            <button type="button" class="action-button action-button--primary" @onclick="SaveItemAsync">
                                @(itemForm.ItemId is null ? "Create menu item" : "Save menu item")
                            </button>
                            <button type="button" class="action-button action-button--secondary" @onclick="StartNewItemForCurrentTab">Clear form</button>
                            @if (itemForm.ItemId is Guid itemId)
                            {
                                <button type="button" class="action-button action-button--success" @onclick="() => ArchiveItemAsync(itemId)">Archive item</button>
                                <button type="button" class="action-button action-button--danger" @onclick="() => ToggleItemDeleteAsync(itemId)">
                                    @(pendingItemDeleteId == itemId ? "Confirm delete" : "Delete item")
                                </button>
                            }
                        </div>

                        <p class="admin-field-note">A single-price item still needs one price variant. Use labels like Regular, Cup, Bowl, Single, or Double when guests need a clearer price breakdown.</p>
                    }
                    else if (detailKind == MenuAdminDetailKind.Special)
                    {
                        <div class="editor-form__grid">
                            <label>
                                Menu tab
                                <select value="@specialForm.Tab" @onchange="HandleSpecialTabChangedAsync">
                                    @foreach (var tab in SpecialTabOptions)
                                    {
                                        <option value="@tab">@GetTabLabel(tab)</option>
                                    }
                                </select>
                            </label>
                            <label>
                                Menu item
                                <select value="@specialForm.LinkedMenuItemId" @onchange="HandleSpecialLinkedItemChangedAsync">
                                    <option value="">Select a menu item</option>
                                    @foreach (var item in SpecialLinkedItemOptions)
                                    {
                                        <option value="@item.ItemId">@GetSpecialLinkedItemOptionLabel(item)</option>
                                    }
                                </select>
                                <small>Specials are item-backed offers. Choose the real menu item first, then add the timing and price modifiers for the offer.</small>
                            </label>
                            <label>
                                Section
                                <input type="text" value="@(SelectedSpecialLinkedItem?.SectionName ?? "Select a menu item first")" disabled />
                                <small>The section follows the linked menu item automatically.</small>
                            </label>
                            <label class="editor-form__message">
                                Item description preview
                                <textarea rows="4" readonly>@(SelectedSpecialLinkedItem?.Description ?? string.Empty)</textarea>
                            </label>
                            <label>
                                Day of week
                                <select @bind="specialForm.DayOfWeek">
                                    @foreach (var day in Enum.GetValues<DayOfWeek>())
                                    {
                                        <option value="@day">@GetDayLabel(day)</option>
                                    }
                                </select>
                            </label>
                            <label>
                                Sort order
                                <input type="number" @bind="specialForm.SortOrder" />
                            </label>
                            <label>
                                Time note
                                <input type="text" @bind="specialForm.TimeNote" />
                                <small>Examples: After 5:00 PM, All day, or 11:00 AM - 2:00 PM.</small>
                            </label>
                            <label>
                                Price or callout
                                <input type="text" @bind="specialForm.PriceNote" />
                            </label>
                            <label class="editor-form__toggle">
                                <span>Guest visibility</span>
                                <div class="editor-form__toggle-row">
                                    <input type="checkbox" @bind="specialForm.IsVisibleToGuests" />
                                    <small>Turn this off when you want to keep the offer stored without showing it to guests.</small>
                                </div>
                            </label>
                            <label class="editor-form__toggle">
                                <span>Archive special</span>
                                <div class="editor-form__toggle-row">
                                    <input type="checkbox" @bind="specialForm.IsArchived" />
                                    <small>Archived specials remain available for reference and future reuse.</small>
                                </div>
                            </label>
                        </div>

                        @if (pendingSpecialDeleteId == specialForm.SpecialId)
                        {
                            <p class="status-banner status-banner--warning">Delete is armed for this special. Click Delete special again to permanently remove it.</p>
                        }

                        <div class="action-row action-row--wrap">
                            <button type="button" class="action-button action-button--primary" @onclick="SaveRecurringSpecialAsync">
                                @(specialForm.SpecialId is null ? "Create special offer" : "Save special offer")
                            </button>
                            <button type="button" class="action-button action-button--secondary" @onclick="StartNewSpecialForCurrentTab">Clear form</button>
                            @if (specialForm.SpecialId is Guid specialId)
                            {
                                <button type="button" class="action-button action-button--success" @onclick="() => ArchiveSpecialAsync(specialId)">Archive special</button>
                                <button type="button" class="action-button action-button--danger" @onclick="() => ToggleSpecialDeleteAsync(specialId)">
                                    @(pendingSpecialDeleteId == specialId ? "Confirm delete" : "Delete special")
                                </button>
                            }
                        </div>

                        <p class="admin-field-note">Recurring specials are item-backed offers. Keep the base item accurate, then use this panel for the day, time, and price modifiers guests should see.</p>
                    }
                </section>
            </div>
        }
    }
</section>
