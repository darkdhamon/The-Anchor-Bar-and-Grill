@page "/admin/menu"
@using Anchor.Domain.Identity
@using Anchor.Domain.Menu
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Policy = ApplicationPolicies.MenuManagement)]

<PageTitle>Menu Editor</PageTitle>

<section class="admin-page menu-admin-page">
    <div class="page-hero page-hero--section">
        <p class="page-hero__eyebrow">Menu Management</p>
        <h1>Menu editor</h1>
        <p class="page-hero__lead">
            Manage fixed public tabs from a browser-style editor. Hours stay in their own workspace, while
            Food and Drinks each use a section tree plus detail panel so staff can review live content before
            saving changes.
        </p>
    </div>

    <StatusMessage Message="@statusMessage" />

    @if (isLoading || menuView is null)
    {
        <section class="admin-card">
            <div class="admin-card__header">
                <h2>Loading menu data</h2>
                <span class="admin-card__badge">Please wait</span>
            </div>
            <p class="admin-field-note">Pulling the latest sections, special items, standard items, and service hours from the catalog.</p>
        </section>
    }
    else
    {
        <section class="admin-card menu-editor-intro">
            <div class="menu-editor-tabs" role="tablist" aria-label="Menu editor workspaces">
                <button type="button"
                        role="tab"
                        class="@GetEditorTabClass(MenuEditorTab.Food)"
                        aria-selected="@(selectedEditorTab == MenuEditorTab.Food)"
                        @onclick="() => SelectEditorTab(MenuEditorTab.Food)">
                    Food
                </button>
                <button type="button"
                        role="tab"
                        class="@GetEditorTabClass(MenuEditorTab.Drinks)"
                        aria-selected="@(selectedEditorTab == MenuEditorTab.Drinks)"
                        @onclick="() => SelectEditorTab(MenuEditorTab.Drinks)">
                    Drinks
                </button>
                <button type="button"
                        role="tab"
                        class="@GetEditorTabClass(MenuEditorTab.Hours)"
                        aria-selected="@(selectedEditorTab == MenuEditorTab.Hours)"
                        @onclick="() => SelectEditorTab(MenuEditorTab.Hours)">
                    Hours
                </button>
            </div>

            <div class="menu-editor-intro__copy">
                <h2>@(selectedEditorTab == MenuEditorTab.Hours ? "Hours workspace" : $"{CurrentWorkspaceLabel} workspace")</h2>
                @if (selectedEditorTab == MenuEditorTab.Hours)
                {
                    <p>
                        Review grouped guest-facing hour summaries for Breakfast, Lunch, Dinner, and Drinks, then open the
                        tab you want to edit with the reusable time combobox fields.
                    </p>
                }
                else if (selectedEditorTab == MenuEditorTab.Food)
                {
                    <p>
                        Browse food sections and edit every food record through one shared item form. Specials are now first-class
                        menu items, so the browser shows one list while the item form reveals extra schedule controls only when
                        <strong>Is special</strong> is enabled.
                    </p>
                }
                else
                {
                    <p>
                        Manage drink sections and beverage items through the same item workflow. Archived content stays in reach
                        through the browser filter so staff can restore or reuse it later.
                    </p>
                }
                <ul class="menu-editor-intro__list">
                    <li>Archive is the safe removal path. Delete still exists, but it always requires a second confirmation.</li>
                    <li>The browser uses Active, Both, and Archived modes plus All, Standard, and Specials filters to focus the current catalog slice.</li>
                    <li>Move buttons and drag-and-drop both reorder sections and item groups. Special items only reorder with other special items so the public menu keeps specials first.</li>
                </ul>
            </div>
        </section>

        @if (selectedEditorTab == MenuEditorTab.Hours)
        {
            <div class="menu-editor-hours-layout">
                <section class="admin-card">
                    <div class="admin-card__header">
                        <h2>Current hour summaries</h2>
                        <span class="admin-card__badge">@HoursSummaryCards.Count tab@(HoursSummaryCards.Count == 1 ? string.Empty : "s")</span>
                    </div>

                    <div class="menu-editor-hours-summaries">
                        @foreach (var hourCard in HoursSummaryCards)
                        {
                            <article class="menu-editor-hours-summary @(serviceWindowForm.Tab == hourCard.Tab ? "is-selected" : null)">
                                <div class="menu-editor-hours-summary__header">
                                    <div>
                                        <p class="menu-editor-hours-summary__eyebrow">@hourCard.Label</p>
                                        <h3>@GetTabLabel(hourCard.Tab)</h3>
                                    </div>
                                    <button type="button"
                                            class="action-button @(serviceWindowForm.Tab == hourCard.Tab ? "action-button--primary" : "action-button--secondary")"
                                            @onclick="() => SelectHoursTabAsync(hourCard.Tab)">
                                        @(serviceWindowForm.Tab == hourCard.Tab ? "Editing" : "Edit hours")
                                    </button>
                                </div>

                                <p class="menu-editor-hours-summary__today">
                                    <span>Today</span>
                                    <strong>@hourCard.Card.TodaySummary</strong>
                                </p>

                                <div class="menu-editor-hours-summary__rows">
                                    @foreach (var row in hourCard.Card.Rows)
                                    {
                                        <div class="menu-editor-hours-summary__row">
                                            <span>@row.Label</span>
                                            <strong>@row.Summary</strong>
                                        </div>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                </section>

                <section class="admin-card">
                    <div class="admin-card__header">
                        <h2>Edit @GetTabLabel(serviceWindowForm.Tab) hours</h2>
                        <span class="admin-card__badge">@(HoursHaveUnsavedChanges ? "Unsaved changes" : "Saved state")</span>
                    </div>

                    <div class="menu-hours-tab-row">
                        @foreach (var tab in HourTabs.OrderBy(tab => tab.Tab))
                        {
                            <button type="button"
                                    class="action-button @(serviceWindowForm.Tab == tab.Tab ? "action-button--primary" : "action-button--secondary")"
                                    @onclick="() => SelectHoursTabAsync(tab.Tab)">
                                @tab.Label
                            </button>
                        }
                    </div>

                    <div class="menu-hours-editor" @key="serviceWindowForm.Tab">
                        @foreach (var day in serviceWindowForm.Days)
                        {
                            <div class="menu-hours-editor__row" @key="(serviceWindowForm.Tab, day.DayOfWeek)">
                                <div class="menu-hours-editor__day">
                                    <strong>@GetDayLabel(day.DayOfWeek)</strong>
                                </div>
                                <label class="menu-hours-editor__toggle">
                                    <span>Available</span>
                                    <input type="checkbox" @bind="day.IsAvailable" />
                                </label>
                                <div>
                                    <label for="@GetHoursInputId(day.DayOfWeek, "open")">Open</label>
                                    <InputTimeComboBox Id="@GetHoursInputId(day.DayOfWeek, "open")"
                                                       @bind-Value="day.OpensAtText"
                                                       Placeholder="Type 1300 or pick a time"
                                                       ToggleAriaLabel="@($"Show {GetDayLabel(day.DayOfWeek)} opening times")"
                                                       Disabled="@(!day.IsAvailable)" />
                                </div>
                                <div>
                                    <label for="@GetHoursInputId(day.DayOfWeek, "close")">Close</label>
                                    <InputTimeComboBox Id="@GetHoursInputId(day.DayOfWeek, "close")"
                                                       @bind-Value="day.ClosesAtText"
                                                       Placeholder="Type 1300 or pick a time"
                                                       ToggleAriaLabel="@($"Show {GetDayLabel(day.DayOfWeek)} closing times")"
                                                       Disabled="@(!day.IsAvailable)" />
                                </div>
                                <label class="menu-hours-editor__toggle">
                                    <span>Closes next day</span>
                                    <input type="checkbox" @bind="day.ClosesNextDay" disabled="@(!day.IsAvailable)" />
                                </label>
                            </div>
                        }
                    </div>

                    <div class="action-row action-row--wrap">
                        <button type="button" class="action-button action-button--primary" @onclick="SaveServiceHoursAsync">
                            Save @GetTabLabel(serviceWindowForm.Tab) hours
                        </button>
                        <button type="button" class="action-button action-button--secondary" @onclick="() => ResetHoursForm(serviceWindowForm.Tab)">
                            Revert changes
                        </button>
                    </div>

                    <p class="admin-field-note">Type shorthand like <code>1300</code>, <code>930</code>, or <code>1pm</code>, or open the list for a nearby half-hour pick. Use <strong>Closes next day</strong> when the tab stays open past midnight.</p>
                </section>
            </div>
        }
        else
        {
            <div class="menu-editor-workspace">
                <section class="admin-card menu-editor-browser">
                    <div class="admin-card__header">
                        <h2>@CurrentWorkspaceLabel browser</h2>
                        <span class="admin-card__badge">@BrowserSections.Count section@(BrowserSections.Count == 1 ? string.Empty : "s")</span>
                    </div>

                    @if (selectedEditorTab == MenuEditorTab.Food)
                    {
                        <div class="menu-editor-filters">
                            <p class="menu-editor-filters__label">Meal filter</p>
                            <div class="chip-list">
                                <button type="button" class="@GetFoodFilterClass(null)" @onclick="() => SelectFoodFilter(null)">All</button>
                                <button type="button" class="@GetFoodFilterClass(MenuTab.Breakfast)" @onclick="() => SelectFoodFilter(MenuTab.Breakfast)">Breakfast</button>
                                <button type="button" class="@GetFoodFilterClass(MenuTab.Lunch)" @onclick="() => SelectFoodFilter(MenuTab.Lunch)">Lunch</button>
                                <button type="button" class="@GetFoodFilterClass(MenuTab.Dinner)" @onclick="() => SelectFoodFilter(MenuTab.Dinner)">Dinner</button>
                            </div>
                        </div>
                    }

                    <div class="menu-editor-filters">
                        <p class="menu-editor-filters__label">Content filter</p>
                        <div class="chip-list">
                            <button type="button" class="@GetContentFilterClass(MenuContentFilter.All)" @onclick="() => SetContentFilter(MenuContentFilter.All)">All</button>
                            <button type="button" class="@GetContentFilterClass(MenuContentFilter.Standard)" @onclick="() => SetContentFilter(MenuContentFilter.Standard)">Standard</button>
                            <button type="button" class="@GetContentFilterClass(MenuContentFilter.Specials)" @onclick="() => SetContentFilter(MenuContentFilter.Specials)">Specials</button>
                        </div>
                    </div>

                    <div class="menu-editor-browser__toolbar">
                        <div class="menu-editor-segmented" role="group" aria-label="Archive filter">
                            <button type="button" class="@GetArchiveFilterClass(MenuArchiveFilter.Active)" @onclick="() => SetArchiveFilter(MenuArchiveFilter.Active)">Active</button>
                            <button type="button" class="@GetArchiveFilterClass(MenuArchiveFilter.Both)" @onclick="() => SetArchiveFilter(MenuArchiveFilter.Both)">Both</button>
                            <button type="button" class="@GetArchiveFilterClass(MenuArchiveFilter.Archived)" @onclick="() => SetArchiveFilter(MenuArchiveFilter.Archived)">Archived</button>
                        </div>

                        <div class="action-row action-row--wrap">
                            <button type="button" class="action-button action-button--primary" @onclick="StartNewSectionForCurrentTab">Add section</button>
                            <button type="button" class="action-button action-button--secondary" disabled="@(!HasItemCreationContext)" @onclick="StartNewItemForCurrentTab">Add item</button>
                            <button type="button" class="action-button action-button--secondary" disabled="@(!HasItemCreationContext)" @onclick="StartNewSpecialItemForCurrentTab">Add special item</button>
                        </div>
                    </div>

                    @if (BrowserSections.Count == 0)
                    {
                        <div class="menu-editor-empty">
                            <h3>No @(CurrentWorkspaceLabel.ToLowerInvariant()) content matches this view yet.</h3>
                            <p>Switch archive modes or create a new section to begin organizing this side of the menu.</p>
                        </div>
                    }
                    else
                    {
                        <div class="menu-editor-tree">
                            @foreach (var browserSection in BrowserSections)
                            {
                                <article class="@GetSectionContainerClass(browserSection)">
                                    <div class="@GetTreeRowClass(MenuAdminDetailKind.Section, browserSection.Section.SectionId, browserSection.Section.IsArchived, browserSection.Section.IsVisibleToGuests)"
                                         draggable="true"
                                         @ondragstart="() => BeginSectionDrag(browserSection.Section)"
                                         @ondragover:preventDefault
                                         @ondrop="() => DropSectionAsync(browserSection.Section)">
                                        <button type="button" class="menu-editor-tree__select" @onclick="() => SelectSection(browserSection.Section)">
                                            <span class="menu-editor-tree__title">@browserSection.Section.Name</span>
                                            <span class="menu-editor-tree__subtitle">@GetFamilyLabel(browserSection.Section.Family) section</span>
                                        </button>

                                        <div class="menu-editor-tree__chips">
                                            <span class="chip chip--neutral">Order @browserSection.Section.SortOrder</span>
                                            @foreach (var label in browserSection.Section.StatusLabels)
                                            {
                                                <span class="status-pill @(GetStatusClass(label))">@label</span>
                                            }
                                        </div>

                                        <div class="menu-editor-tree__actions">
                                            <button type="button"
                                                    class="menu-editor-tree__icon-button"
                                                    title="Move section up"
                                                    disabled="@(!CanMoveSection(browserSection.Section, -1))"
                                                    @onclick="() => MoveSectionAsync(browserSection.Section, -1)">
                                                Up
                                            </button>
                                            <button type="button"
                                                    class="menu-editor-tree__icon-button"
                                                    title="Move section down"
                                                    disabled="@(!CanMoveSection(browserSection.Section, 1))"
                                                    @onclick="() => MoveSectionAsync(browserSection.Section, 1)">
                                                Down
                                            </button>
                                            <button type="button" class="menu-editor-tree__quick-action" @onclick="() => StartNewItemFromSection(browserSection.Section, false)">+ Item</button>
                                            <button type="button" class="menu-editor-tree__quick-action" @onclick="() => StartNewItemFromSection(browserSection.Section, true)">+ Special item</button>
                                        </div>
                                    </div>

                                    @if (browserSection.Items.Count > 0)
                                    {
                                        <div class="menu-editor-tree__group">
                                            <p class="menu-editor-tree__group-label">Items</p>
                                            @foreach (var itemEntry in browserSection.Items)
                                            {
                                                <div class="@GetTreeRowClass(MenuAdminDetailKind.Item, itemEntry.Item.ItemId, itemEntry.Item.IsArchived, itemEntry.Item.IsVisibleToGuests, itemEntry.IsContextMuted)"
                                                     draggable="true"
                                                     @ondragstart="() => BeginItemDrag(itemEntry.Item)"
                                                     @ondragover:preventDefault
                                                     @ondrop="() => DropItemAsync(itemEntry.Item)">
                                                    <button type="button" class="menu-editor-tree__select" @onclick="() => SelectItem(itemEntry.Item)">
                                                        <span class="menu-editor-tree__title">@itemEntry.Item.Name</span>
                                                        <span class="menu-editor-tree__subtitle">@GetItemBrowserSubtitle(itemEntry.Item)</span>
                                                    </button>

                                                    <div class="menu-editor-tree__chips">
                                                        <span class="chip chip--neutral">@GetPriceSummary(itemEntry.Item)</span>
                                                        @if (itemEntry.Item.Special is not null)
                                                        {
                                                            <span class="chip chip--info">@itemEntry.Item.Special.BadgeLabel</span>
                                                        }
                                                        @foreach (var label in itemEntry.Item.StatusLabels)
                                                        {
                                                            <span class="status-pill @(GetStatusClass(label))">@label</span>
                                                        }
                                                    </div>

                                                    <div class="menu-editor-tree__actions">
                                                        <button type="button"
                                                                class="menu-editor-tree__icon-button"
                                                                title="Move item up"
                                                                disabled="@(!CanMoveItem(itemEntry.Item, -1))"
                                                                @onclick="() => MoveItemAsync(itemEntry.Item, -1)">
                                                            Up
                                                        </button>
                                                        <button type="button"
                                                                class="menu-editor-tree__icon-button"
                                                                title="Move item down"
                                                                disabled="@(!CanMoveItem(itemEntry.Item, 1))"
                                                                @onclick="() => MoveItemAsync(itemEntry.Item, 1)">
                                                            Down
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </article>
                            }
                        </div>
                    }
                </section>

                <section class="admin-card menu-editor-detail">
                    <div class="admin-card__header">
                        <h2>@CurrentDetailTitle</h2>
                        <span class="admin-card__badge">@(CurrentDetailHasUnsavedChanges ? "Unsaved changes" : "Saved state")</span>
                    </div>

                    @if (detailKind == MenuAdminDetailKind.None)
                    {
                        <div class="menu-editor-empty">
                            <h3>Select a section or item to edit it.</h3>
                            <p>The browser stays on the left so staff can scan structure first, then use the detail panel for explicit saves.</p>
                        </div>
                    }
                    else if (detailKind == MenuAdminDetailKind.Section)
                    {
                        <div class="editor-form">
                            <div class="editor-form__grid">
                                <label>
                                    <span>Section name</span>
                                    <input type="text" @bind="sectionForm.Name" placeholder="Appetizers, Wings, Cocktails..." />
                                </label>

                                <label>
                                    <span>Family</span>
                                    <select @bind="sectionForm.Family">
                                        <option value="@MenuFamily.Food">Food</option>
                                        <option value="@MenuFamily.Drink">Drink</option>
                                    </select>
                                </label>

                                <label>
                                    <span>Sort order</span>
                                    <input type="number" @bind="sectionForm.SortOrder" />
                                </label>

                                <div class="editor-form__toggle">
                                    <label class="editor-form__toggle-row">
                                        <input type="checkbox" @bind="sectionForm.IsVisibleToGuests" />
                                        <span>
                                            Show this section to guests
                                            <small>Hidden sections stay available in the editor so staff can continue staging content.</small>
                                        </span>
                                    </label>
                                </div>

                                <div class="editor-form__toggle">
                                    <label class="editor-form__toggle-row">
                                        <input type="checkbox" @bind="sectionForm.IsArchived" />
                                        <span>
                                            Archive this section
                                            <small>Archived sections stay stored for later reuse. They remain hidden from guests.</small>
                                        </span>
                                    </label>
                                </div>
                            </div>

                            @if (pendingSectionDeleteId == sectionForm.SectionId)
                            {
                                <p class="admin-field-note">Click delete again to permanently remove this section. Sections with dependent items cannot be deleted until those items are moved or removed.</p>
                            }

                            <div class="action-row action-row--wrap">
                                <button type="button" class="action-button action-button--primary" @onclick="SaveSectionAsync">
                                    @(sectionForm.SectionId is null ? "Create section" : "Save section")
                                </button>
                                <button type="button" class="action-button action-button--secondary" @onclick="ResetCurrentDetail">
                                    @(sectionForm.SectionId is null ? "Clear section form" : "Revert changes")
                                </button>
                                @if (sectionForm.SectionId is Guid sectionId)
                                {
                                    <button type="button"
                                            class="action-button action-button--secondary"
                                            disabled="@sectionForm.IsArchived"
                                            @onclick="() => ArchiveSectionAsync(sectionId)">
                                        Archive section
                                    </button>
                                    <button type="button" class="action-button action-button--danger" @onclick="() => ToggleSectionDeleteAsync(sectionId)">
                                        @(pendingSectionDeleteId == sectionId ? "Confirm delete section" : "Delete section")
                                    </button>
                                }
                            </div>
                        </div>
                    }
                    else if (detailKind == MenuAdminDetailKind.Item)
                    {
                        <div class="editor-form">
                            <div class="editor-form__grid">
                                <label>
                                    <span>Section</span>
                                    <select value="@itemForm.SectionId" @onchange="HandleItemSectionChangedAsync">
                                        @foreach (var section in ItemSectionOptions)
                                        {
                                            <option value="@section.SectionId">@section.Name</option>
                                        }
                                    </select>
                                </label>

                                <label>
                                    <span>Sort order</span>
                                    <input type="number" @bind="itemForm.SortOrder" />
                                </label>

                                <label>
                                    <span>Name</span>
                                    <input type="text" @bind="itemForm.Name" placeholder="Classic hamburger, wing night, old fashioned..." />
                                </label>

                                <label>
                                    <span>Image path or URL</span>
                                    <input type="text" @bind="itemForm.ImagePath" placeholder="/images/menu/wings.jpg" />
                                </label>

                                <label class="editor-form__message">
                                    <span>Description</span>
                                    <textarea @bind="itemForm.Description" placeholder="Describe what guests should know about this item."></textarea>
                                </label>

                                <div class="editor-form__message">
                                    <span>Price variants</span>
                                    <div class="menu-editor-price-list">
                                        @foreach (var variant in itemForm.PriceVariants)
                                        {
                                            <div class="menu-editor-price-row">
                                                <label>
                                                    <span>Label</span>
                                                    <input type="text" @bind="variant.Label" placeholder="Regular, Basket, Single..." />
                                                </label>
                                                <label>
                                                    <span>Amount</span>
                                                    <input type="text" @bind="variant.AmountText" placeholder="9.00" />
                                                </label>
                                                <button type="button"
                                                        class="menu-editor-tree__icon-button"
                                                        disabled="@(itemForm.PriceVariants.Count == 1)"
                                                        @onclick="() => RemovePriceVariant(variant)">
                                                    Remove
                                                </button>
                                            </div>
                                        }
                                    </div>
                                    <button type="button" class="action-button action-button--secondary" @onclick="AddPriceVariant">Add price variant</button>
                                </div>

                                @if (GetItemEditorFamily() == MenuFamily.Food)
                                {
                                    <div class="editor-form__message">
                                        <span>Guest tabs</span>
                                        <div class="menu-editor-checkbox-stack">
                                            <label class="editor-form__toggle-row">
                                                <input type="checkbox" @bind="itemForm.ShowBreakfast" />
                                                <span>Breakfast</span>
                                            </label>
                                            <label class="editor-form__toggle-row">
                                                <input type="checkbox" @bind="itemForm.ShowLunch" />
                                                <span>Lunch</span>
                                            </label>
                                            <label class="editor-form__toggle-row">
                                                <input type="checkbox" @bind="itemForm.ShowDinner" />
                                                <span>Dinner</span>
                                            </label>
                                        </div>
                                    </div>
                                }

                                <div class="editor-form__toggle">
                                    <label class="editor-form__toggle-row">
                                        <input type="checkbox" @bind="itemForm.IsVisibleToGuests" />
                                        <span>
                                            Show this item to guests
                                            <small>Hidden items stay in the editor but do not show on the public menu.</small>
                                        </span>
                                    </label>
                                </div>

                                <div class="editor-form__toggle">
                                    <label class="editor-form__toggle-row">
                                        <input type="checkbox" @bind="itemForm.IsArchived" />
                                        <span>
                                            Archive this item
                                            <small>Archived items stay stored for future reuse and appear greyed out in the browser.</small>
                                        </span>
                                    </label>
                                </div>

                                <div class="editor-form__toggle">
                                    <label class="editor-form__toggle-row">
                                        <input type="checkbox" checked="@itemForm.IsSpecial" @onchange="HandleSpecialToggleChangedAsync" />
                                        <span>
                                            Is special
                                            <small>Turn this on when the item is a recurring or dated special. Shared item fields stay here, and special-only schedule fields appear below.</small>
                                        </span>
                                    </label>
                                </div>

                                @if (!itemForm.IsSpecial)
                                {
                                    <label>
                                        <span>Offer start date</span>
                                        <input type="text" @bind="itemForm.OfferStartsOnText" placeholder="YYYY-MM-DD" />
                                    </label>

                                    <label>
                                        <span>Offer end date</span>
                                        <input type="text" @bind="itemForm.OfferEndsOnText" placeholder="YYYY-MM-DD" />
                                    </label>

                                    <div class="editor-form__toggle">
                                        <label class="editor-form__toggle-row">
                                            <input type="checkbox" @bind="itemForm.IsSeasonal" />
                                            <span>
                                                Seasonal item
                                                <small>Use this for normal menu items that should show a seasonal badge while their date window is active.</small>
                                            </span>
                                        </label>
                                    </div>
                                }
                                else
                                {
                                    <div class="editor-form__message menu-editor-special-settings">
                                        <div class="admin-card__header">
                                            <h3>Special settings</h3>
                                            <span class="admin-card__badge">Item extension</span>
                                        </div>

                                        <div class="editor-form__grid">
                                            <label>
                                                <span>Schedule type</span>
                                                <select @bind="itemForm.SpecialScheduleKind">
                                                    <option value="@MenuItemSpecialScheduleKind.WeeklyRecurring">Weekly recurring</option>
                                                    <option value="@MenuItemSpecialScheduleKind.Dated">Dated</option>
                                                </select>
                                            </label>

                                            @if (itemForm.SpecialScheduleKind == MenuItemSpecialScheduleKind.WeeklyRecurring)
                                            {
                                                <label>
                                                    <span>Weekday</span>
                                                    <select @bind="itemForm.SpecialDayOfWeek">
                                                        @foreach (var day in Enum.GetValues<DayOfWeek>())
                                                        {
                                                            <option value="@day">@GetDayLabel(day)</option>
                                                        }
                                                    </select>
                                                </label>
                                            }

                                            <label>
                                                <span>Start date</span>
                                                <input type="text" @bind="itemForm.SpecialStartDateText" placeholder="YYYY-MM-DD" />
                                            </label>

                                            <label>
                                                <span>End date</span>
                                                <input type="text" @bind="itemForm.SpecialEndDateText" placeholder="YYYY-MM-DD" />
                                            </label>

                                            <div>
                                                <label for="special-start-time">Start time</label>
                                                <InputTimeComboBox Id="special-start-time"
                                                                   @bind-Value="itemForm.SpecialStartsAtText"
                                                                   Placeholder="Optional"
                                                                   ToggleAriaLabel="Show special start times" />
                                            </div>

                                            <div>
                                                <label for="special-end-time">End time</label>
                                                <InputTimeComboBox Id="special-end-time"
                                                                   @bind-Value="itemForm.SpecialEndsAtText"
                                                                   Placeholder="Optional"
                                                                   ToggleAriaLabel="Show special end times" />
                                            </div>

                                            <div class="editor-form__toggle">
                                                <label class="editor-form__toggle-row">
                                                    <input type="checkbox" @bind="itemForm.SpecialClosesNextDay" />
                                                    <span>
                                                        Closes next day
                                                        <small>Use this when a special starts late and ends after midnight.</small>
                                                    </span>
                                                </label>
                                            </div>

                                            <label class="editor-form__message">
                                                <span>Short callout</span>
                                                <input type="text" @bind="itemForm.SpecialCallout" placeholder="After 5 PM, while supplies last, bar-only..." />
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>

                            @if (itemForm.ItemId is Guid existingItemId && pendingItemDeleteId == existingItemId)
                            {
                                <p class="admin-field-note">Click delete again to permanently remove this item. Special items are deleted as a whole item record together with their special extension.</p>
                            }

                            <div class="action-row action-row--wrap">
                                <button type="button" class="action-button action-button--primary" @onclick="SaveItemAsync">
                                    @(itemForm.ItemId is null ? (itemForm.IsSpecial ? "Create special item" : "Create item") : (itemForm.IsSpecial ? "Save special item" : "Save item"))
                                </button>
                                <button type="button" class="action-button action-button--secondary" @onclick="ResetCurrentDetail">
                                    @(itemForm.ItemId is null ? (itemForm.IsSpecial ? "Clear special form" : "Clear item form") : "Revert changes")
                                </button>
                                @if (itemForm.ItemId is Guid itemId)
                                {
                                    <button type="button"
                                            class="action-button action-button--secondary"
                                            disabled="@itemForm.IsArchived"
                                            @onclick="() => ArchiveItemAsync(itemId)">
                                        Archive item
                                    </button>
                                    <button type="button" class="action-button action-button--danger" @onclick="() => ToggleItemDeleteAsync(itemId)">
                                        @(pendingItemDeleteId == itemId ? "Confirm delete item" : "Delete item")
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </section>
            </div>
        }
    }
</section>
