@page "/admin/contact"

<PageTitle>Contact Admin</PageTitle>

<section class="admin-page">
    <div class="page-hero page-hero--section">
        <p class="page-hero__eyebrow">Admin Mockup</p>
        <h1>Contact admin</h1>
        <p class="page-hero__lead">
            This page mockup shows how staff could maintain contact details, preview hours, and shape the guest inquiry experience in one place.
        </p>
    </div>

    <div class="admin-grid">
        <aside class="admin-help">
            <h2>How this page should work</h2>
            <ul>
                <li>Keep address, phone, and hours editable without hunting through multiple screens.</li>
                <li>Explain which contact fields guests will actually see on the website.</li>
                <li>Allow multiple social media profiles so the public page can show a main page plus any extra platform-specific or campaign-specific accounts.</li>
                <li>Use a clear confirmation pattern before removing hours or contact methods.</li>
            </ul>
        </aside>

        <div class="admin-stack">
            <section class="admin-card">
                <div class="admin-card__header">
                    <h2>Contact details form</h2>
                    <span class="admin-card__badge">Guest Facing</span>
                </div>

                <div class="editor-form__grid">
                    <label>
                        Street address
                        <input type="text" value="@MockupContent.Contact.StreetAddress" />
                    </label>
                    <label>
                        City and state
                        <input type="text" value="@MockupContent.Contact.CityState" />
                    </label>
                    <label>
                        Phone number
                        <input type="text" value="@MockupContent.Contact.PhoneNumber" />
                    </label>
                    <label class="editor-form__message">
                        Guest contact note
                        <textarea rows="4">Use for takeout questions, event inquiries, and same-day updates.</textarea>
                    </label>
                </div>
            </section>

            <section class="admin-card">
                <div class="admin-card__header">
                    <h2>Hours preview</h2>
                    <span class="admin-card__badge">Edit + Delete</span>
                </div>

                <div class="admin-list">
                    @foreach (var item in MockupContent.PreviewHours)
                    {
                        <article class="admin-list__item">
                            <div>
                                <h3>@item.Label</h3>
                                <p>@item.Hours</p>
                            </div>
                            <div class="admin-list__actions">
                                <button type="button">Edit</button>
                                <button type="button" class="admin-list__danger">Delete</button>
                            </div>
                        </article>
                    }
                </div>
            </section>

            <section class="admin-card">
                <div class="admin-card__header">
                    <h2>Social profiles</h2>
                    <span class="admin-card__badge">Add + Edit + Delete</span>
                </div>

                <div class="editor-form">
                    <h3>Profile editor</h3>
                    <div class="editor-form__grid">
                        <label>
                            Platform
                            <input type="text" list="social-platform-options" value="@exampleProfile.Platform" />
                            <small>Choose an existing platform or type a new one when the business adds another social channel.</small>
                        </label>
                        <label>
                            Profile label
                            <input type="text" value="@exampleProfile.ProfileLabel" />
                        </label>
                        <label>
                            Profile URL
                            <input type="text" value="@exampleProfile.Url" />
                        </label>
                        <label class="editor-form__message">
                            Guest-facing note
                            <textarea rows="4">@exampleProfile.Description</textarea>
                        </label>
                    </div>

                    <datalist id="social-platform-options">
                        @foreach (var platform in socialPlatformOptions)
                        {
                            <option value="@platform"></option>
                        }
                    </datalist>

                    <button type="button" class="hero-actions__link hero-actions__link--secondary">Add another profile</button>
                </div>

                <div class="admin-list">
                    @foreach (var item in MockupContent.SocialProfiles)
                    {
                        <article class="admin-list__item">
                            <div>
                                <h3>@item.Platform</h3>
                                <p class="contact-channel__value social-profile__link social-profile__link--static">@item.ProfileLabel</p>
                                <p class="social-profile__url">@item.Url</p>
                                <p>@item.Description</p>
                            </div>
                            <div class="admin-list__actions">
                                <button type="button">Edit</button>
                                <button type="button" class="admin-list__danger">Delete</button>
                            </div>
                        </article>
                    }
                </div>
            </section>
        </div>
    </div>
</section>

@code {
    private static readonly IReadOnlyList<string> socialPlatformOptions = MockupContent.SocialPlatformOptions;
    private static readonly SocialProfile exampleProfile = MockupContent.SocialProfiles[0];
}
