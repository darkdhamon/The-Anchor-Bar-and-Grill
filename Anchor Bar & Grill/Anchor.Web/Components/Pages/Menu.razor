@page "/menu"
@using Anchor.Domain.Menu
@attribute [ExcludeFromInteractiveRouting]

<PageTitle>Menu</PageTitle>

<div class="menu-page">
    @if (menuView is null)
    {
        <section class="page-hero page-hero--section">
            <p class="page-hero__eyebrow">Food &amp; Drink</p>
            <h1>Menu</h1>
            <p class="page-hero__lead">Loading the latest menu details.</p>
        </section>
    }
    else
    {
        <section class="page-hero page-hero--section">
            <p class="page-hero__eyebrow">Food &amp; Drink</p>
            <h1>Browse the menu</h1>
            <p class="page-hero__lead">
                Choose Breakfast, Lunch, Dinner, or Drinks from the sidebar to switch the active service hours
                and the menu sections guests can order from right now.
            </p>
        </section>

        <section class="section-shell">
            <div class="menu-layout">
                <aside class="feature-card feature-card--tight menu-sidebar" aria-label="Menu navigation">
                    <div class="menu-sidebar__header">
                        <p class="feature-card__eyebrow">Menu</p>
                        <h2>Browse by service</h2>
                    </div>

                    <nav class="menu-sidebar__nav" aria-label="Menu tabs">
                        @foreach (var tab in menuView.Tabs)
                        {
                            <a class="menu-tab-link @(tab.IsSelected ? "menu-tab-link--selected" : string.Empty)"
                               href="@GetTabHref(tab.QueryValue)"
                               data-enhance-nav="false">
                                <div class="menu-tab-link__topline">
                                    <span class="menu-tab-link__label">@tab.Label</span>

                                    @if (!tab.HasVisibleContent)
                                    {
                                        <span class="menu-tab-link__hint">Coming soon</span>
                                    }
                                </div>
                            </a>
                        }
                    </nav>

                    <section class="menu-hours-card menu-sidebar__hours" aria-label="@($"{GetSelectedTabLabel(menuView.SelectedTab)} hours")">
                        <div class="menu-hours-card__header">
                            <p class="feature-card__eyebrow">Weekly availability</p>
                            <h2>@GetSelectedTabLabel(menuView.SelectedTab) hours</h2>
                        </div>

                        <div class="hours-list">
                            @foreach (var row in menuHoursCard.Rows)
                            {
                                <div class="hours-row @(row.IncludesToday ? "hours-row--today" : null)">
                                    <div class="hours-row__copy">
                                        <span class="hours-row__label">@row.Label</span>
                                        @if (row.IncludesToday)
                                        {
                                            <span class="hours-row__today-pill">Today</span>
                                        }
                                    </div>
                                    <span class="hours-row__summary">@row.Summary</span>
                                </div>
                            }
                        </div>
                    </section>
                </aside>

                <div class="menu-content-stack">
                    @if (menuView.Sections.Count == 0)
                    {
                        <article class="feature-card menu-empty-state">
                            <p class="feature-card__eyebrow">@GetSelectedTabLabel(menuView.SelectedTab)</p>
                            <h2>@GetEmptyStateTitle(menuView.SelectedTab)</h2>
                            <p>@GetEmptyStateDescription(menuView.SelectedTab)</p>
                        </article>
                    }
                    else
                    {
                        <div class="menu-accordion">
                            @foreach (var section in menuView.Sections.Select((value, index) => new { value, index }))
                            {
                                <details class="menu-accordion__section menu-section @section.value.AccentClass" open="@(section.index == 0 ? "open" : null)">
                                    <summary class="menu-section__summary">
                                        <div class="menu-section__summary-copy">
                                            <h2>@section.value.Name</h2>
                                            <span class="menu-section__count">@(section.value.Items.Count == 1 ? "1 item" : $"{section.value.Items.Count} items")</span>
                                        </div>
                                    </summary>

                                    <div class="menu-section__items">
                                        @foreach (var item in section.value.Items)
                                        {
                                            <article class="menu-item @(item.ImagePath is not null ? "menu-item--with-image" : "menu-item--text-only") @(item.Special is not null ? "menu-item--special" : string.Empty)">
                                                @if (item.ImagePath is not null)
                                                {
                                                    <div class="menu-item__visual">
                                                        <img class="menu-item__image" src="@item.ImagePath" alt="@item.Name" />
                                                    </div>
                                                }

                                                <div class="menu-item__content">
                                                    @if (item.Special is not null)
                                                    {
                                                        <div class="menu-item__badges">
                                                            <span class="status-pill status-pill--schedule">@item.Special.BadgeLabel</span>
                                                            @if (item.Special.IsToday)
                                                            {
                                                                <span class="status-pill status-pill--today">Today</span>
                                                            }
                                                            @if (!string.IsNullOrWhiteSpace(item.Special.Callout))
                                                            {
                                                                <span class="status-pill status-pill--limited">@item.Special.Callout</span>
                                                            }
                                                        </div>
                                                    }

                                                    <div class="menu-item__title-row">
                                                        <h3>@item.Name</h3>
                                                        <span>@GetPriceSummary(item)</span>
                                                    </div>

                                                    @if (item.PriceVariants.Count > 1)
                                                    {
                                                        <div class="menu-item__price-stack">
                                                            @foreach (var variant in item.PriceVariants)
                                                            {
                                                                <div class="menu-item__price-line">
                                                                    <span class="menu-item__price-label">@variant.Label</span>
                                                                    <span class="menu-item__price-value">@variant.PriceDisplay</span>
                                                                </div>
                                                            }
                                                        </div>
                                                    }

                                                    @if (item.StatusLabels.Count > 0)
                                                    {
                                                        <div class="menu-item__badges">
                                                            @foreach (var label in item.StatusLabels)
                                                            {
                                                                <span class="status-pill @(GetBadgeClass(label))">@label</span>
                                                            }
                                                        </div>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(item.Description))
                                                    {
                                                        <p>@item.Description</p>
                                                    }

                                                    @if (item.Special is { } special)
                                                    {
                                                        <p class="event-card__meta">@special.ScheduleSummary</p>

                                                        @if (!string.IsNullOrWhiteSpace(special.TimeSummary))
                                                        {
                                                            <p class="menu-item__offer-range">@special.TimeSummary</p>
                                                        }
                                                    }

                                                    @if (item.OfferDateSummary is { } offerSummary)
                                                    {
                                                        <p class="menu-item__offer-range">@offerSummary</p>
                                                    }
                                                </div>
                                            </article>
                                        }
                                    </div>
                                </details>
                            }
                        </div>
                    }
                </div>
            </div>
        </section>
    }
</div>
